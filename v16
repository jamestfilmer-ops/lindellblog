<script>
function showView(view, btn) {
  const home = document.getElementById('view-home');
  const article = document.getElementById('view-article');
  const btns = document.querySelectorAll('.ml-btn');

  if (view === 'home') {
    home.style.display = 'block';
    article.style.display = 'none';
    // reset animation
    home.style.animation = 'none';
    home.offsetHeight;
    home.style.animation = '';
  } else {
    home.style.display = 'none';
    article.style.display = 'block';
    article.style.animation = 'none';
    article.offsetHeight;
    article.style.animation = '';
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  // update mockup label buttons
  btns.forEach(b => b.classList.remove('active'));
  if (btn) {
    btn.classList.add('active');
  } else {
    btns[view === 'home' ? 0 : 1].classList.add('active');
  }
}

function switchTab(el, label) {
  document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('section-label').textContent = label;
  // update count display
  const counts = { 'Short Stories': '7 pieces', 'Think Pieces': '4 pieces' };
  document.querySelector('.section-count').textContent = counts[label] || '';
}

// init
document.getElementById('view-article').style.display = 'none';
