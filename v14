<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lindell's Blog — Brand Concepts v2</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500;1,600&family=Playfair+Display:ital,wght@0,400;0,500;0,700;0,900;1,400;1,700&family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Cinzel:wght@400;500;600;700&family=Crimson+Pro:ital,wght@0,200;0,300;0,400;0,600;1,200;1,300;1,400&family=DM+Serif+Display:ital@0;1&family=Fraunces:ital,opsz,wght@0,9..144,100;0,9..144,300;0,9..144,400;0,9..144,700;1,9..144,100;1,9..144,300;1,9..144,400&family=Bodoni+Moda:ital,opsz,wght@0,6..96,400;0,6..96,500;0,6..96,700;1,6..96,400;1,6..96,700&family=Josefin+Sans:ital,wght@0,100;0,200;0,300;0,400;1,100;1,200&family=Raleway:ital,wght@0,100;0,200;0,300;0,400;1,100;1,200&family=Tenor+Sans&family=Questrial&family=Sorts+Mill+Goudy:ital@0;1&family=GFS+Didot:ital@0;1&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}

:root {
  --chrome-bg: #F7F4EF;
  --chrome-border: #e0d8cc;
  --chrome-text: #1a1a1a;
  --chrome-muted: #888;
  --chrome-accent: #2a2a2a;
}

body {
  background: var(--chrome-bg);
  color: var(--chrome-text);
  font-family: 'EB Garamond', Georgia, serif;
  min-height: 100vh;
}

/* ── CHROME ── */
.page-header {
  padding: 3rem 3rem 0;
  border-bottom: 1px solid var(--chrome-border);
}
.page-header-top {
  display: flex; align-items: flex-end; justify-content: space-between;
  padding-bottom: 1.5rem;
}
.header-eyebrow {
  font-family: 'Cinzel', serif;
  font-size: 0.6rem; letter-spacing: 0.35em; text-transform: uppercase;
  color: var(--chrome-muted); margin-bottom: 0.5rem;
}
.header-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(2rem, 4vw, 3.5rem);
  font-weight: 300; color: #111; line-height: 1;
}
.header-title em { font-style: italic; color: #555; }
.header-sub {
  font-size: 0.88rem; color: var(--chrome-muted); font-style: italic;
  max-width: 340px; line-height: 1.5; text-align: right;
}

/* Tab nav */
.tab-row {
  display: flex; gap: 0;
}
.tab-btn {
  background: transparent; border: none;
  font-family: 'Cinzel', serif; font-size: 0.62rem; letter-spacing: 0.2em;
  text-transform: uppercase; color: var(--chrome-muted);
  padding: 0.9rem 1.5rem; cursor: pointer;
  border-bottom: 2px solid transparent;
  transition: all 0.2s;
}
.tab-btn:hover { color: #333; }
.tab-btn.active { color: #111; border-bottom-color: #111; }

/* Filter row */
.filter-row {
  padding: 1rem 3rem;
  display: flex; gap: 0.5rem; align-items: center;
  border-bottom: 1px solid var(--chrome-border);
}
.filter-label {
  font-family: 'Cinzel', serif; font-size: 0.55rem; letter-spacing: 0.25em;
  text-transform: uppercase; color: var(--chrome-muted); margin-right: 0.5rem;
}
.filter-chip {
  background: transparent; border: 1px solid var(--chrome-border);
  color: var(--chrome-muted); font-family: 'Cinzel', serif;
  font-size: 0.55rem; letter-spacing: 0.15em; text-transform: uppercase;
  padding: 0.3rem 0.8rem; cursor: pointer; border-radius: 20px;
  transition: all 0.2s;
}
.filter-chip.active, .filter-chip:hover {
  background: #111; color: #fff; border-color: #111;
}

/* ── GRID ── */
.concepts-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(420px, 1fr));
  gap: 1px;
  background: var(--chrome-border);
  border-top: 1px solid var(--chrome-border);
}

.concept-card {
  background: var(--chrome-bg);
  cursor: pointer;
  position: relative;
  overflow: hidden;
  transition: box-shadow 0.3s;
}
.concept-card:hover { box-shadow: 0 8px 40px rgba(0,0,0,0.12); z-index: 5; }

.concept-preview {
  height: 540px;
  overflow: hidden;
  position: relative;
  display: flex; flex-direction: column;
}

/* hover reveal */
.concept-meta {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 1.2rem 1.5rem;
  background: rgba(255,255,255,0.95);
  border-top: 1px solid rgba(0,0,0,0.07);
  transform: translateY(100%);
  transition: transform 0.3s ease;
  z-index: 20;
}
.concept-card:hover .concept-meta { transform: translateY(0); }
.meta-number {
  font-family: 'Cinzel', serif; font-size: 0.55rem; letter-spacing: 0.25em;
  color: #bbb; margin-bottom: 0.2rem;
}
.meta-name {
  font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; color: #111;
  font-style: italic;
}
.meta-sub { font-size: 0.78rem; color: #888; margin-top: 0.1rem; }
.meta-fonts { font-size: 0.7rem; color: #aaa; margin-top: 0.35rem; font-style: italic; }
.meta-choose {
  margin-top: 0.75rem;
  background: #111; color: #fff; border: none;
  font-family: 'Cinzel', serif; font-size: 0.55rem; letter-spacing: 0.2em;
  text-transform: uppercase; padding: 0.5rem 1.2rem; cursor: pointer;
  transition: background 0.2s;
}
.meta-choose:hover { background: #333; }

.card-badge {
  position: absolute; top: 1rem; left: 1rem; z-index: 10;
  font-family: 'Cinzel', serif; font-size: 0.52rem; letter-spacing: 0.2em;
  text-transform: uppercase; padding: 0.28rem 0.7rem;
  background: rgba(255,255,255,0.9); color: #555;
  border: 1px solid rgba(0,0,0,0.1); border-radius: 20px;
}

/* ══════════════════════════════════════════════
   CONCEPT A: VIA COMO — Classic
   Cormorant Garamond + terracotta + lake blue
══════════════════════════════════════════════ */
.pa { background: #FAFAF7; font-family: 'Cormorant Garamond', serif; }
.pa-nav {
  padding: 1.1rem 1.8rem; display: flex; align-items: center;
  justify-content: space-between; border-bottom: 1px solid #e8e0d4;
}
.pa-logo { font-size: 1.05rem; color: #1a3040; font-weight: 300; letter-spacing: 0.05em; font-style: italic; }
.pa-tabs {
  display: flex; gap: 0;
}
.pa-tab {
  font-family: 'Cinzel', serif; font-size: 0.58rem; letter-spacing: 0.18em;
  text-transform: uppercase; padding: 0.3rem 0.9rem; color: #aaa;
  border-bottom: 1.5px solid transparent;
}
.pa-tab.active { color: #1a3040; border-bottom-color: #C86A4A; }
.pa-feature { padding: 1.5rem 1.8rem; border-bottom: 1px solid #e8e0d4; }
.pa-label { color: #C86A4A; font-size: 0.58rem; letter-spacing: 0.3em; font-family: 'Cinzel', serif; text-transform: uppercase; margin-bottom: 0.5rem; }
.pa-title { color: #1a2830; font-size: 2.1rem; font-weight: 300; line-height: 1.1; margin-bottom: 0.2rem; }
.pa-title em { font-style: italic; font-weight: 400; }
.pa-loc { color: #6FA3B8; font-size: 0.72rem; font-style: italic; letter-spacing: 0.05em; margin-bottom: 0.65rem; }
.pa-text { color: #3a3028; font-size: 0.87rem; line-height: 1.8; }
.pa-rule { height: 1px; background: linear-gradient(to right, #C86A4A, #6FA3B8, transparent); opacity: 0.3; margin: 1rem 1.8rem; }
.pa-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0; }
.pa-card { padding: 1rem 1.8rem; border-top: 1px solid #e8e0d4; }
.pa-card:first-child { border-right: 1px solid #e8e0d4; }
.pa-card-label { color: #C86A4A; font-size: 0.55rem; letter-spacing: 0.25em; font-family: 'Cinzel', serif; text-transform: uppercase; }
.pa-card-title { color: #1a2830; font-size: 0.92rem; margin-top: 0.2rem; font-style: italic; line-height: 1.3; }

/* ══════════════════════════════════════════════
   CONCEPT B: VIA COMO — Modern Bold
   Bodoni Moda display + sans accent, cleaner
══════════════════════════════════════════════ */
.pb { background: #FFFFFF; font-family: 'Bodoni Moda', serif; }
.pb-nav {
  padding: 1.2rem 2rem; display: flex; align-items: center;
  justify-content: space-between;
  border-bottom: 2px solid #111;
}
.pb-logo { font-size: 1rem; color: #111; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; font-family: 'Josefin Sans', sans-serif; }
.pb-tabs { display: flex; gap: 0; }
.pb-tab { font-family: 'Josefin Sans', sans-serif; font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; padding: 0.3rem 1rem; color: #ccc; border-bottom: 2px solid transparent; margin-bottom: -2px; }
.pb-tab.active { color: #111; border-bottom-color: #6FA3B8; }
.pb-hero { padding: 2rem 2rem 1.2rem; }
.pb-kicker { font-family: 'Josefin Sans', sans-serif; font-size: 0.58rem; letter-spacing: 0.3em; text-transform: uppercase; color: #6FA3B8; margin-bottom: 0.6rem; }
.pb-title { font-size: 3rem; font-weight: 700; line-height: 0.95; color: #111; margin-bottom: 0.5rem; letter-spacing: -0.02em; }
.pb-title em { font-style: italic; font-weight: 400; color: #666; }
.pb-meta { font-family: 'Josefin Sans', sans-serif; font-size: 0.6rem; letter-spacing: 0.2em; color: #bbb; text-transform: uppercase; margin-bottom: 0.8rem; }
.pb-text { font-size: 0.88rem; line-height: 1.75; color: #444; font-family: 'Crimson Pro', serif; }
.pb-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 0; border-top: 1px solid #eee; }
.pb-card { padding: 1rem 2rem; }
.pb-card:first-child { border-right: 1px solid #eee; }
.pb-card-kicker { font-family: 'Josefin Sans', sans-serif; font-size: 0.55rem; letter-spacing: 0.2em; text-transform: uppercase; color: #6FA3B8; }
.pb-card-title { font-size: 1rem; margin-top: 0.2rem; color: #111; font-style: italic; }

/* ══════════════════════════════════════════════
   CONCEPT C: REGATTA — Classic
   Libre Baskerville + Navy + Red
══════════════════════════════════════════════ */
.pc { background: #F8F7F4; font-family: 'Libre Baskerville', serif; }
.pc-header { background: #1E2F44; padding: 0 1.8rem; display: flex; align-items: center; justify-content: space-between; }
.pc-logo { color: #fff; font-size: 0.9rem; letter-spacing: 0.12em; text-transform: uppercase; font-family: 'Cinzel', serif; padding: 1.1rem 0; }
.pc-tabs { display: flex; }
.pc-tab { font-family: 'Cinzel', serif; font-size: 0.57rem; letter-spacing: 0.18em; text-transform: uppercase; padding: 1.1rem 0.9rem; color: rgba(255,255,255,0.4); border-bottom: 2px solid transparent; }
.pc-tab.active { color: #fff; border-bottom-color: #B23A2B; }
.pc-red { height: 3px; background: #B23A2B; }
.pc-body { padding: 1.5rem 1.8rem; }
.pc-edition { font-family: 'Cinzel', serif; font-size: 0.57rem; letter-spacing: 0.3em; text-transform: uppercase; color: #B23A2B; margin-bottom: 0.5rem; }
.pc-title { font-size: 2rem; line-height: 1.1; color: #1E2F44; margin-bottom: 0.25rem; }
.pc-byline { font-size: 0.7rem; font-style: italic; color: #8a9aaa; margin-bottom: 0.75rem; }
.pc-text { font-size: 0.84rem; line-height: 1.72; color: #2a3545; }
.pc-rule { border: none; border-top: 1px solid #dde3ea; margin: 1rem 0; }
.pc-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
.pc-card { border-top: 3px solid #1E2F44; padding-top: 0.6rem; }
.pc-card-ed { font-family: 'Cinzel', serif; font-size: 0.53rem; letter-spacing: 0.18em; text-transform: uppercase; color: #B23A2B; }
.pc-card-title { font-size: 0.88rem; margin-top: 0.2rem; color: #1E2F44; }

/* ══════════════════════════════════════════════
   CONCEPT D: REGATTA — Superyacht Modern
   Raleway ultralight + sharp navy geometry
══════════════════════════════════════════════ */
.pd { background: #F5F7FA; font-family: 'Raleway', sans-serif; }
.pd-nav {
  background: #fff;
  padding: 0 2rem;
  display: flex; align-items: center; justify-content: space-between;
  border-bottom: 1px solid #e0e6ee;
  box-shadow: 0 1px 0 rgba(30,47,68,0.04);
}
.pd-logo { font-weight: 200; font-size: 1.1rem; letter-spacing: 0.2em; text-transform: uppercase; color: #1E2F44; padding: 1.2rem 0; }
.pd-tabs { display: flex; }
.pd-tab { font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; font-weight: 400; padding: 1.2rem 1rem; color: #bbb; border-bottom: 2px solid transparent; margin-bottom: -1px; }
.pd-tab.active { color: #1E2F44; border-bottom-color: #1E2F44; }
.pd-hero { padding: 2.5rem 2rem 1.5rem; background: #fff; border-bottom: 1px solid #e8ecf2; }
.pd-kicker { font-size: 0.58rem; letter-spacing: 0.35em; text-transform: uppercase; color: #7a9fc0; font-weight: 300; margin-bottom: 0.6rem; }
.pd-title { font-size: 2.8rem; font-weight: 200; line-height: 1; color: #0d1f35; letter-spacing: -0.01em; margin-bottom: 0.4rem; }
.pd-title strong { font-weight: 600; }
.pd-date { font-size: 0.6rem; letter-spacing: 0.22em; text-transform: uppercase; color: #bbb; font-weight: 300; margin-bottom: 0.8rem; }
.pd-text { font-size: 0.83rem; line-height: 1.8; color: #445; font-family: 'Crimson Pro', serif; font-weight: 300; }
.pd-cards { display: grid; grid-template-columns: 1fr 1fr; background: #F5F7FA; }
.pd-card { padding: 1.2rem 2rem; border-right: 1px solid #e0e6ee; }
.pd-card:last-child { border-right: none; }
.pd-card-kicker { font-size: 0.55rem; letter-spacing: 0.25em; text-transform: uppercase; color: #7a9fc0; font-weight: 300; }
.pd-card-title { font-size: 0.9rem; font-weight: 300; color: #0d1f35; margin-top: 0.2rem; font-family: 'Raleway', sans-serif; letter-spacing: 0.03em; }

/* ══════════════════════════════════════════════
   CONCEPT E: WHITE SAIL — Pure Literary
   Sorts Mill Goudy, single gold rule
══════════════════════════════════════════════ */
.pe { background: #FDFCF9; font-family: 'Sorts Mill Goudy', serif; }
.pe-nav { padding: 1.5rem 2.5rem; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid #ece6dc; }
.pe-logo { font-size: 1.05rem; color: #1a1a1a; letter-spacing: 0.04em; }
.pe-gold { height: 1px; background: #b8965a; width: 36px; margin-top: 0.3rem; }
.pe-tabs { display: flex; gap: 0; }
.pe-tab { font-family: 'Cinzel', serif; font-size: 0.57rem; letter-spacing: 0.2em; text-transform: uppercase; padding: 0 0.9rem; color: #ccc; border-bottom: 1px solid transparent; padding-bottom: 0.1rem; }
.pe-tab.active { color: #1a1a1a; border-bottom-color: #b8965a; }
.pe-body { padding: 2rem 2.5rem; }
.pe-title { font-size: 2.3rem; line-height: 1.05; color: #1a1a1a; margin-bottom: 0.25rem; }
.pe-date { font-family: 'Cinzel', serif; font-size: 0.58rem; letter-spacing: 0.2em; color: #b8965a; margin-bottom: 1rem; }
.pe-text { font-size: 0.9rem; line-height: 1.88; color: #2a2520; }
.pe-text::first-letter { font-size: 3.5rem; float: left; line-height: 0.72; margin: 0.05rem 0.4rem 0 0; color: #1a1a1a; }
.pe-rule { border: none; border-top: 1px solid #ece6dc; margin: 1.2rem 0; }
.pe-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; }
.pe-card-title { font-size: 0.92rem; color: #1a1a1a; font-style: italic; line-height: 1.3; }
.pe-card-date { font-family: 'Cinzel', serif; font-size: 0.55rem; letter-spacing: 0.15em; color: #b8965a; margin-top: 0.2rem; }

/* ══════════════════════════════════════════════
   CONCEPT F: WHITE SAIL — Elevated Modern
   Fraunces optical variable, ultra clean
══════════════════════════════════════════════ */
.pf { background: #FEFEFE; font-family: 'Fraunces', serif; }
.pf-nav { padding: 1.4rem 2.5rem; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid #f0ebe3; }
.pf-logo { font-size: 1.1rem; font-weight: 100; letter-spacing: 0.08em; color: #111; }
.pf-logo span { font-weight: 400; font-style: italic; }
.pf-tabs { display: flex; }
.pf-tab { font-family: 'Josefin Sans', sans-serif; font-size: 0.56rem; letter-spacing: 0.2em; text-transform: uppercase; padding: 0 0.8rem; color: #ddd; font-weight: 300; }
.pf-tab.active { color: #111; }
.pf-body { padding: 2.2rem 2.5rem; }
.pf-eyebrow { font-family: 'Josefin Sans', sans-serif; font-size: 0.56rem; letter-spacing: 0.3em; text-transform: uppercase; color: #bbb; font-weight: 300; margin-bottom: 0.6rem; }
.pf-title { font-size: 2.6rem; font-weight: 300; line-height: 1; color: #111; margin-bottom: 0.3rem; font-style: italic; }
.pf-title span { font-style: normal; font-weight: 100; color: #aaa; font-size: 1.8rem; }
.pf-sub { font-family: 'Josefin Sans', sans-serif; font-size: 0.58rem; letter-spacing: 0.15em; text-transform: uppercase; color: #ccc; font-weight: 300; margin-bottom: 0.9rem; }
.pf-text { font-size: 0.87rem; line-height: 1.85; color: #333; font-weight: 300; }
.pf-divider { display: flex; align-items: center; gap: 0.75rem; margin: 1rem 0; }
.pf-divider-line { flex: 1; height: 1px; background: #f0ebe3; }
.pf-divider-dot { width: 4px; height: 4px; background: #ccc; border-radius: 50%; }
.pf-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; }
.pf-card-title { font-size: 0.95rem; font-weight: 300; font-style: italic; color: #222; }
.pf-card-sub { font-family: 'Josefin Sans', sans-serif; font-size: 0.53rem; letter-spacing: 0.15em; text-transform: uppercase; color: #bbb; margin-top: 0.2rem; font-weight: 300; }

/* ══════════════════════════════════════════════
   CONCEPT G: THE ATLAS — Classic
   GFS Didot + corner ornaments
══════════════════════════════════════════════ */
.pg { background: #F6F1E9; font-family: 'GFS Didot', serif; position: relative; }
.pg-corner { position: absolute; width: 18px; height: 18px; border-color: #8B6B3A; border-style: solid; z-index: 5; }
.pg-corner.tl { top: 10px; left: 10px; border-width: 2px 0 0 2px; }
.pg-corner.tr { top: 10px; right: 10px; border-width: 2px 2px 0 0; }
.pg-corner.bl { bottom: 10px; left: 10px; border-width: 0 0 2px 2px; }
.pg-corner.br { bottom: 10px; right: 10px; border-width: 0 2px 2px 0; }
.pg-nav { padding: 1.2rem 2rem; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid rgba(80,60,30,0.2); }
.pg-logo { font-size: 1.1rem; color: #2C1F10; font-style: italic; }
.pg-logo span { color: #8B6B3A; font-style: normal; }
.pg-tabs { display: flex; }
.pg-tab { font-family: 'Cinzel', serif; font-size: 0.57rem; letter-spacing: 0.18em; text-transform: uppercase; padding: 0 0.8rem; color: #c5b090; border-bottom: 1px solid transparent; }
.pg-tab.active { color: #2C1F10; border-bottom-color: #8B6B3A; }
.pg-body { padding: 1.4rem 2rem; }
.pg-roman { font-family: 'Cinzel', serif; font-size: 0.58rem; letter-spacing: 0.3em; text-transform: uppercase; color: #8B6B3A; margin-bottom: 0.5rem; }
.pg-title { font-size: 2rem; line-height: 1.1; color: #1a1008; margin-bottom: 0.2rem; }
.pg-place { font-size: 0.75rem; color: #8B6B3A; font-style: italic; margin-bottom: 0.7rem; }
.pg-text { font-size: 0.85rem; line-height: 1.75; color: #2a1f14; }
.pg-rule { height: 1px; background: linear-gradient(to right, transparent, rgba(80,60,30,0.3), transparent); margin: 0.9rem 0; }
.pg-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem; }
.pg-card { border: 1px solid rgba(80,60,30,0.15); padding: 0.75rem; }
.pg-card-roman { font-family: 'Cinzel', serif; font-size: 0.53rem; letter-spacing: 0.2em; text-transform: uppercase; color: #8B6B3A; }
.pg-card-title { font-size: 0.88rem; color: #2a1f14; font-style: italic; margin-top: 0.15rem; }

/* ══════════════════════════════════════════════
   CONCEPT H: THE ATLAS — Luxury Travel Magazine
   Tenor Sans + DM Serif, modern-luxe
══════════════════════════════════════════════ */
.ph { background: #FAFAF8; font-family: 'DM Serif Display', serif; }
.ph-nav { background: #fff; padding: 0 2rem; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid #eeebe4; }
.ph-logo { font-family: 'Tenor Sans', sans-serif; font-size: 0.85rem; letter-spacing: 0.28em; text-transform: uppercase; color: #111; padding: 1.2rem 0; }
