<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lindell's Blog</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Lora:ital,wght@0,400;0,500;1,400&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --cream: #f5f0e8;
    --ink: #1a1410;
    --warm-gray: #7a726a;
    --rust: #b5451b;
    --gold: #c9952a;
    --soft-bg: #ede8de;
    --rule: #c8bfb0;
  }

  html { scroll-behavior: smooth; }

  body {
    background-color: var(--cream);
    color: var(--ink);
    font-family: 'Lora', Georgia, serif;
    font-size: 17px;
    line-height: 1.75;
    overflow-x: hidden;
  }

  /* --- MASTHEAD --- */
  .masthead {
    border-bottom: 3px double var(--ink);
    padding: 0 2rem 0;
    text-align: center;
    position: relative;
    background: var(--cream);
  }
  .masthead-rule-top {
    display: block;
    height: 1px;
    background: var(--ink);
    margin-bottom: 1.5rem;
  }
  .masthead-eyebrow {
    font-family: 'DM Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--warm-gray);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }
  .masthead-eyebrow span { flex-shrink: 0; }
  .masthead-eyebrow::before,
  .masthead-eyebrow::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--rule);
  }
  .masthead h1 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(3.5rem, 8vw, 7rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 0.4rem;
    color: var(--ink);
  }
  .masthead-sub {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 1.05rem;
    color: var(--warm-gray);
    margin-bottom: 1.6rem;
  }
  nav {
    display: flex;
    justify-content: center;
    gap: 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    margin-bottom: 0;
    padding: 0.55rem 0;
  }
  nav a {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    padding: 0 1.6rem;
    border-right: 1px solid var(--rule);
    transition: color 0.2s;
  }
  nav a:first-child { border-left: 1px solid var(--rule); }
  nav a:hover { color: var(--rust); }

  /* --- LAYOUT --- */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 4rem;
    padding: 3.5rem 0 5rem;
    align-items: start;
  }

  /* --- FEATURED POST --- */
  .featured {
    border-bottom: 2px solid var(--ink);
    padding-bottom: 2.5rem;
    margin-bottom: 2.5rem;
    position: relative;
  }
  .featured-tag {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--rust);
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1rem;
  }
  .featured-tag::after {
    content: '';
    display: inline-block;
    width: 30px;
    height: 1px;
    background: var(--rust);
  }
  .featured h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }
  .featured h2 a { color: var(--ink); text-decoration: none; }
  .featured h2 a:hover { color: var(--rust); }
  .meta {
    font-family: 'DM Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    color: var(--warm-gray);
    text-transform: uppercase;
    margin-bottom: 1.2rem;
  }
  .excerpt {
    color: #3a342c;
    font-size: 1.02rem;
    line-height: 1.8;
    margin-bottom: 1.4rem;
    font-style: italic;
  }
  .read-more {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1.5px solid var(--ink);
    padding-bottom: 1px;
    transition: color 0.2s, border-color 0.2s;
  }
  .read-more:hover { color: var(--rust); border-color: var(--rust); }

  /* --- POST LIST --- */
  .post-list { display: flex; flex-direction: column; gap: 0; }
  .post-item {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 1.5rem;
    padding: 1.8rem 0;
    border-bottom: 1px solid var(--rule);
    align-items: start;
    opacity: 0;
    transform: translateY(16px);
    animation: fadeUp 0.5s ease forwards;
  }
  .post-item:nth-child(1) { animation-delay: 0.1s; }
  .post-item:nth-child(2) { animation-delay: 0.2s; }
  .post-item:nth-child(3) { animation-delay: 0.3s; }
  .post-item:nth-child(4) { animation-delay: 0.4s; }

  @keyframes fadeUp {
    to { opacity: 1; transform: translateY(0); }
  }

  .post-date-col {
    text-align: right;
    padding-top: 0.25rem;
    border-right: 1px solid var(--rule);
    padding-right: 1.5rem;
  }
  .post-day {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    font-weight: 700;
    line-height: 1;
    color: var(--ink);
    display: block;
  }
  .post-month {
    font-family: 'DM Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--warm-gray);
    display: block;
  }
  .post-year {
    font-family: 'DM Mono', monospace;
    font-size: 0.58rem;
    color: var(--rule);
    display: block;
    margin-top: 2px;
  }
  .post-body {}
  .post-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.3rem;
  }
  .post-item h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 0.5rem;
  }
  .post-item h3 a { color: var(--ink); text-decoration: none; }
  .post-item h3 a:hover { color: var(--rust); }
  .post-snippet {
    font-size: 0.93rem;
    color: var(--warm-gray);
    line-height: 1.65;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* --- SIDEBAR --- */
  .sidebar { position: sticky; top: 2rem; }
  .sidebar-section {
    margin-bottom: 2.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--rule);
  }
  .sidebar-section:last-child { border-bottom: none; }
  .sidebar-heading {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--warm-gray);
    margin-bottom: 1.2rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .sidebar-heading::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--rule);
  }

  /* About card */
  .about-card {
    background: var(--soft-bg);
    padding: 1.5rem;
    border: 1px solid var(--rule);
  }
  .about-avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    border: 2px solid var(--rule);
    display: block;
    margin-bottom: 0.9rem;
    object-fit: cover;
  }
  .about-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.3rem;
  }
  .about-bio {
    font-size: 0.88rem;
    color: var(--warm-gray);
    line-height: 1.6;
  }

  /* Labels */
  .label-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .label-tag {
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    border: 1px solid var(--rule);
    padding: 0.3rem 0.65rem;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }
  .label-tag:hover {
    background: var(--ink);
    color: var(--cream);
    border-color: var(--ink);
  }

  /* Archive */
  .archive-list { list-style: none; }
  .archive-list li {
    display: flex;
    justify-content: space-between;
    padding: 0.45rem 0;
    border-bottom: 1px dotted var(--rule);
    font-size: 0.9rem;
  }
  .archive-list li:last-child { border-bottom: none; }
  .archive-list a { color: var(--ink); text-decoration: none; }
  .archive-list a:hover { color: var(--rust); }
  .archive-count {
    font-family: 'DM Mono', monospace;
    font-size: 0.68rem;
    color: var(--warm-gray);
  }

  /* --- FOOTER --- */
  footer {
    border-top: 3px double var(--ink);
    padding: 2.5rem 2rem;
    text-align: center;
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--warm-gray);
  }
  footer strong {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 1rem;
    letter-spacing: 0;
    text-transform: none;
    color: var(--ink);
    font-weight: 400;
  }

  /* decorative drop cap */
  .drop-cap::first-letter {
    font-family: 'Playfair Display', serif;
    font-size: 4rem;
    font-weight: 700;
    float: left;
    line-height: 0.8;
    margin-right: 0.12em;
    margin-top: 0.08em;
    color: var(--rust);
  }

  /* pull quote ornament */
  .ornament {
    text-align: center;
    color: var(--rule);
    font-size: 1.5rem;
    letter-spacing: 0.3em;
    margin: 1rem 0;
    user-select: none;
  }

  @media (max-width: 768px) {
    .layout { grid-template-columns: 1fr; gap: 2.5rem; }
    .sidebar { position: static; }
    nav a { padding: 0 0.8rem; font-size: 0.62rem; }
  }
</style>
</head>
