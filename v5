<script>
const nav = document.getElementById('nav');
const photo = document.getElementById('hero-photo');

window.addEventListener('scroll', () => {
  const y = window.scrollY;
  nav.classList.toggle('solid', y > 55);
  if (photo) photo.style.transform = `scale(1.06) translateY(${y * 0.2}px)`;
}, { passive: true });

const io = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (!e.isIntersecting) return;
    const el = e.target;
    if (el.classList.contains('post-row')) {
      const rows = [...document.querySelectorAll('.post-row')];
      setTimeout(() => el.classList.add('show'), rows.indexOf(el) * 100);
    } else {
      el.classList.add('show');
    }
    io.unobserve(el);
  });
}, { threshold: 0.1 });

['featured','sb1','sb2','sb3','quote-inner'].forEach(id => {
  const el = document.getElementById(id);
  if (el) io.observe(el);
});
document.querySelectorAll('.post-row').forEach(el => io.observe(el));
</script>
