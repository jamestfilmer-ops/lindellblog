<div id="modal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.85); z-index:100; display:none; align-items:center; justify-content:center; padding:2rem; backdrop-filter:blur(8px);">
  <div style="background:#161616; border:1px solid #2a2a2a; max-width:500px; width:100%; padding:2.5rem; position:relative;">
    <button onclick="closeModal()" style="position:absolute; top:1rem; right:1rem; background:transparent; border:none; color:#555; font-size:1.2rem; cursor:pointer;">✕</button>
