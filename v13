      <button onclick="selectFinal()" style="background:#b8965a; border:none; color:#0e0e0e; font-family:'Cinzel',serif; font-size:0.6rem; letter-spacing:0.2em; padding:0.5rem 1.5rem; cursor:pointer; font-weight:700;">✓ CHOOSE THIS ONE</button>
