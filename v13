<script>
const concepts = {
  1: { name: "The Logbook", sub: "Nautical Captain's Journal", body: "Navy + brass palette. Each entry dated with GPS-style coordinates — 44°N 11°E, like a ship's log. Rope-style dividers, structured log-entry formatting. Posts feel like dispatches from sea." },
  2: { name: "Pub Notebook", sub: "Irish Literary Corner", body: "British racing green header, cream paper body with subtle texture, leather brown accents, gold dividers. Feels like scribbled notes from a quiet corner booth at closing time. Drop-cap letters on every story." },
  3: { name: "The Field Dispatch", sub: "Explorer's Journal", body: "Parchment background, brown leather accents, ink-black type. Dotted map-path dividers between sections. Drop-cap letters. A faint compass rose watermarks each article. Like a 19th-century expedition notebook." },
  4: { name: "The Reading Room", sub: "Victorian Dark Library", body: "Dark forest green backgrounds, ivory text, gold accents. A flickering candle emoji animates at the top of every page. Articles labeled as 'Volumes.' Feels like a private Victorian reading room." },
  5: { name: "Regatta", sub: "Yacht Club Classic", body: "Navy + white + regatta red horizontal stripe accents. Posts labeled as 'Editions' like a sailing club newsletter. Clean, crisp, New England coastal energy. The most buttoned-up of the 15." },
  6: { name: "Via Como", sub: "Italian Lakeside Summer", body: "The lightest, airiest concept. Villa cream, terracotta accents, lake blue, olive green. A watercolor-wash header tints each article. European summer travel diary feeling." },
  7: { name: "The Gilt Press", sub: "High Editorial Magazine", body: "Bold black masthead with gold lettering. Strong typographic hierarchy. Posts divided into Fiction, Essays, Commentary, Travel. Feels like a high-end literary magazine." },
  8: { name: "Mahogany & Brass", sub: "Golden Age Seafarer", body: "Deep sea green backgrounds, brass gold accents, subtle diagonal hatching texture suggesting old nautical charts. Compass rose section dividers. Posts labeled as 'Charts' and 'Voyages.'" },
  9: { name: "White Sail", sub: "Pure Minimal Literary", body: "Extreme minimalism. Pure cream paper, one serif typeface, one thin gold rule — that's it. No nav clutter, no color. Drop-cap first letter. Reads like a beautifully typeset novella. Best for long-form fiction and essays." },
  10: { name: "The Correspondent", sub: "Foreign Dateline Journal", body: "Every post opens with a newspaper-style dateline — 'DUBLIN — March 10, 2026.' A top bar shows cities you've filed from. Amber dateline stripe. Feels like dispatches from a traveling journalist." },
  11: { name: "The Crypt", sub: "Gothic Dark Academia", body: "Near-black background, deep crimson accents, corner vignette. Posts labeled as 'Confessions.' Gothic dark academia aesthetic — moody, intellectual, slightly ominous. Best for darker fiction and introspective essays." },
  12: { name: "Broadside", sub: "Old Newspaper Broadsheet", body: "Two-column newspaper layout with a centered masthead, volume number, and date bar. Featured story left, sidebar right. Drop-cap first letter. Like a personal literary gazette — Vol. I, No. 7." },
  13: { name: "Ember", sub: "Warm Lantern Glow", body: "Deep near-black background with a radial amber glow at the top — like a lantern or fireside. Amber accent color throughout. The warmest of the dark themes. Intimate, inviting." },
  14: { name: "The Atlas", sub: "Illustrated Travel Tome", body: "Parchment background with decorative corner ornaments (like an old book). Roman numerals label each entry. Thin ruled border around the entire page. Posts labeled as 'Territories' and 'Expeditions.'" },
  15: { name: "Indigo Ink", sub: "Coastal Midnight", body: "Deep midnight indigo background with a faint star-field and a crescent moon silhouette. Wave-line dividers. Nav items: Tides, Depths, Shores. The most poetic and atmospheric of all 15 concepts." }
};

let currentConcept = null;

function selectConcept(n) {
  currentConcept = n;
  const c = concepts[n];
  document.getElementById('modal-num').textContent = `CONCEPT ${String(n).padStart(2,'0')}`;
  document.getElementById('modal-name').textContent = c.name;
  document.getElementById('modal-sub').textContent = c.sub;
  document.getElementById('modal-body').textContent = c.body;
  const modal = document.getElementById('modal');
  modal.style.display = 'flex';
}

function closeModal() {
  document.getElementById('modal').style.display = 'none';
}

function selectFinal() {
  const c = concepts[currentConcept];
  alert(`✓ "${c.name}" selected! Tell Claude you want to build this one and we'll start the full Vercel build.`);
  closeModal();
}

function filterAll(btn) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.concept-card').forEach(c => c.style.display = '');
}

function filterGroup(btn, tag) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.concept-card').forEach(c => {
    const tags = c.dataset.tags || '';
    c.style.display = tags.includes(tag) ? '' : 'none';
  });
}

document.getElementById('modal').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});
</script>
