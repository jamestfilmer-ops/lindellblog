<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lindell's Blog — Brand Concepts</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600&family=Playfair+Display:ital,wght@0,400;0,500;0,700;0,900;1,400;1,700&family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Crimson+Text:ital,wght@0,400;0,600;1,400;1,600&family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Spectral:ital,wght@0,300;0,400;0,500;1,300;1,400&family=UnifrakturMaguntia&family=Cinzel:wght@400;500;600;700&family=Sorts+Mill+Goudy:ital@0;1&family=GFS+Didot:ital@0;1&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --ui-bg: #0e0e0e;
    --ui-surface: #161616;
    --ui-border: #2a2a2a;
    --ui-text: #c8c0b4;
    --ui-accent: #b8965a;
    --ui-muted: #5a5a5a;
  }

  body {
    background: var(--ui-bg);
    color: var(--ui-text);
    font-family: 'EB Garamond', Georgia, serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ---- CHROME ---- */
  .chrome-header {
    padding: 3rem 2rem 2rem;
    text-align: center;
    border-bottom: 1px solid var(--ui-border);
    position: relative;
  }
  .chrome-header::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(184,150,90,0.08) 0%, transparent 70%);
    pointer-events: none;
  }
  .chrome-eyebrow {
    font-family: 'Cinzel', serif;
    font-size: 0.65rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--ui-accent);
    margin-bottom: 1rem;
  }
  .chrome-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.2rem, 5vw, 4rem);
    font-weight: 300;
    color: #e8dfd0;
    line-height: 1.1;
    margin-bottom: 0.75rem;
  }
  .chrome-sub {
    font-size: 1.05rem;
    color: var(--ui-muted);
    font-style: italic;
    max-width: 500px;
    margin: 0 auto;
  }

  .filter-bar {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    flex-wrap: wrap;
    padding: 1.5rem 2rem;
    border-bottom: 1px solid var(--ui-border);
  }
  .filter-btn {
    background: transparent;
    border: 1px solid var(--ui-border);
    color: var(--ui-muted);
    font-family: 'Cinzel', serif;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.45rem 1rem;
    cursor: pointer;
    transition: all 0.2s;
    border-radius: 2px;
  }
  .filter-btn:hover, .filter-btn.active {
    border-color: var(--ui-accent);
    color: var(--ui-accent);
    background: rgba(184,150,90,0.06);
  }

  /* ---- GRID ---- */
  .concepts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
    gap: 2px;
    padding: 2px;
  }

  .concept-card {
    position: relative;
    cursor: pointer;
    overflow: hidden;
    transition: transform 0.3s ease;
  }
  .concept-card:hover { z-index: 10; transform: scale(1.01); }

  .concept-preview {
    width: 100%;
    height: 520px;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .card-overlay {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 1.5rem;
    background: linear-gradient(transparent, rgba(0,0,0,0.85));
    z-index: 20;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .concept-card:hover .card-overlay { opacity: 1; }
  .overlay-name {
    font-family: 'Cinzel', serif;
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    color: #fff;
    margin-bottom: 0.25rem;
  }
  .overlay-desc {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.75);
    font-style: italic;
  }

  .concept-number {
    position: absolute;
    top: 1rem;
    right: 1rem;
    font-family: 'Cinzel', serif;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    padding: 0.3rem 0.6rem;
    background: rgba(0,0,0,0.5);
    color: rgba(255,255,255,0.6);
    border: 1px solid rgba(255,255,255,0.15);
    z-index: 30;
    border-radius: 2px;
  }

  /* ===================================================
     CONCEPT 1: THE LOGBOOK — Nautical Captain's Journal
  =================================================== */
  .preview-1 {
    background: #0B2545;
    font-family: 'Playfair Display', serif;
    padding: 0;
  }
  .p1-header {
    background: #071830;
    padding: 1.4rem 1.8rem;
    border-bottom: 2px solid #B08D57;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .p1-logo { color: #FAF8F3; font-size: 1.1rem; font-weight: 700; letter-spacing: 0.05em; }
  .p1-nav { display: flex; gap: 1.2rem; }
  .p1-nav span { color: #B08D57; font-size: 0.65rem; letter-spacing: 0.2em; font-family: 'Cinzel', serif; text-transform: uppercase; }
  .p1-hero {
    padding: 1.8rem;
    border-bottom: 1px solid rgba(176,141,87,0.25);
  }
  .p1-coords { color: #3E6C8F; font-size: 0.65rem; letter-spacing: 0.2em; font-family: 'Cinzel', serif; margin-bottom: 0.4rem; }
  .p1-entry-label { color: #B08D57; font-size: 0.6rem; letter-spacing: 0.3em; text-transform: uppercase; font-family: 'Cinzel', serif; margin-bottom: 0.6rem; }
  .p1-title { color: #FAF8F3; font-size: 1.8rem; line-height: 1.15; margin-bottom: 0.5rem; font-style: italic; }
  .p1-dateline { color: #3E6C8F; font-size: 0.75rem; font-style: italic; margin-bottom: 0.8rem; }
  .p1-excerpt { color: rgba(250,248,243,0.7); font-size: 0.85rem; line-height: 1.65; font-family: 'EB Garamond', serif; }
  .p1-divider { height: 1px; background: linear-gradient(to right, transparent, #B08D57, transparent); margin: 0.8rem 0; }
  .p1-cards { padding: 1rem 1.8rem; display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem; }
  .p1-card { border: 1px solid rgba(176,141,87,0.2); padding: 0.8rem; }
  .p1-card-coords { color: #3E6C8F; font-size: 0.55rem; letter-spacing: 0.15em; font-family: 'Cinzel', serif; }
  .p1-card-title { color: #FAF8F3; font-size: 0.85rem; margin-top: 0.2rem; font-style: italic; }
  .p1-anchor { position: absolute; bottom: 1.2rem; left: 1.8rem; color: rgba(176,141,87,0.3); font-size: 2.5rem; }

  /* ===================================================
     CONCEPT 2: PUB NOTEBOOK — Irish Literary Corner
  =================================================== */
  .preview-2 {
    background: #F5EDD8;
    font-family: 'Libre Baskerville', serif;
    position: relative;
  }
  .p2-noise {
    position: absolute; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none; z-index: 1;
  }
  .p2-header {
    background: #1B4332;
    padding: 1.2rem 1.8rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative; z-index: 2;
  }
  .p2-logo { color: #F5EDD8; font-size: 1.15rem; font-weight: 700; }
  .p2-nav span { color: rgba(245,237,216,0.65); font-size: 0.62rem; letter-spacing: 0.18em; font-family: 'Cinzel', serif; margin-left: 1rem; }
  .p2-gold-rule { height: 2px; background: linear-gradient(to right, #1B4332, #C9A84C, #1B4332); position: relative; z-index: 2; }
  .p2-body { padding: 1.6rem 1.8rem; position: relative; z-index: 2; }
  .p2-kicker { color: #1B4332; font-size: 0.6rem; letter-spacing: 0.3em; text-transform: uppercase; font-family: 'Cinzel', serif; margin-bottom: 0.5rem; }
  .p2-title { color: #1C1008; font-size: 1.9rem; line-height: 1.15; margin-bottom: 0.3rem; }
  .p2-title em { color: #4A3728; }
  .p2-date { color: #8B6B47; font-size: 0.75rem; font-style: italic; margin-bottom: 0.75rem; }
  .p2-text { color: #2C1F10; font-size: 0.83rem; line-height: 1.75; }
  .p2-text::first-letter { font-size: 2.8rem; float: left; line-height: 0.8; margin: 0.1rem 0.4rem 0 0; color: #1B4332; font-family: 'Cormorant Garamond', serif; font-weight: 700; }
  .p2-divider { border: none; border-top: 1px solid #C9A84C; margin: 1rem 0; opacity: 0.5; }
  .p2-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
  .p2-card { border-left: 2px solid #C9A84C; padding-left: 0.75rem; }
  .p2-card-cat { color: #1B4332; font-size: 0.55rem; letter-spacing: 0.2em; font-family: 'Cinzel', serif; text-transform: uppercase; }
  .p2-card-title { color: #1C1008; font-size: 0.82rem; margin-top: 0.15rem; font-style: italic; }

  /* ===================================================
     CONCEPT 3: THE FIELD DISPATCH — Explorer's Journal
  =================================================== */
  .preview-3 {
    background: #F4ECD8;
    font-family: 'Cormorant Garamond', serif;
    position: relative;
    overflow: hidden;
  }
  .p3-map-bg {
    position: absolute; inset: 0;
    opacity: 0.06;
    background-image:
      repeating-linear-gradient(0deg, #5A3B27 0, #5A3B27 1px, transparent 0, transparent 50%),
      repeating-linear-gradient(90deg, #5A3B27 0, #5A3B27 1px, transparent 0, transparent 50%);
    background-size: 30px 30px;
  }
  .p3-header {
    background: #5A3B27;
    padding: 1.1rem 1.8rem;
    display: flex; align-items: center; justify-content: space-between;
    position: relative; z-index: 2;
  }
  .p3-logo { color: #F4ECD8; font-size: 1.1rem; font-weight: 600; letter-spacing: 0.05em; font-style: italic; }
  .p3-compass { color: #C9A05A; font-size: 1.2rem; }
  .p3-body { padding: 1.5rem 1.8rem; position: relative; z-index: 2; }
  .p3-tag { display: inline-block; border: 1px solid #5A3B27; color: #5A3B27; font-size: 0.58rem; letter-spacing: 0.25em; padding: 0.2rem 0.6rem; font-family: 'Cinzel', serif; text-transform: uppercase; margin-bottom: 0.7rem; }
  .p3-title { color: #1C1C1C; font-size: 2rem; line-height: 1.1; font-weight: 600; margin-bottom: 0.25rem; }
  .p3-title em { font-weight: 300; }
  .p3-sub { color: #6C7A5B; font-size: 0.78rem; font-style: italic; margin-bottom: 0.75rem; }
  .p3-text { color: #2a1f14; font-size: 0.85rem; line-height: 1.7; }
  .p3-text::first-letter { font-size: 3rem; float: left; line-height: 0.75; margin: 0.05rem 0.35rem 0 0; color: #5A3B27; font-weight: 700; }
  .p3-dotpath { display: flex; align-items: center; gap: 0.3rem; margin: 0.9rem 0; }
  .p3-dot { width: 4px; height: 4px; border-radius: 50%; background: #5A3B27; opacity: 0.5; }
  .p3-path { flex: 1; border-top: 1px dashed #5A3B27; opacity: 0.35; }
  .p3-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 0.7rem; }
  .p3-card { background: rgba(90,59,39,0.07); padding: 0.75rem; border-top: 2px solid #5A3B27; }
  .p3-card-tag { color: #5A3B27; font-size: 0.55rem; letter-spacing: 0.2em; font-family: 'Cinzel', serif; text-transform: uppercase; }
  .p3-card-title { color: #1C1C1C; font-size: 0.83rem; margin-top: 0.2rem; font-style: italic; }
  .p3-watermark { position: absolute; bottom: -10px; right: -10px; font-size: 7rem; color: rgba(90,59,39,0.06); z-index: 1; line-height: 1; }

  /* ===================================================
     CONCEPT 4: THE READING ROOM — Victorian Dark Library
  =================================================== */
  .preview-4 {
    background: #0F1F14;
    font-family: 'Playfair Display', serif;
    position: relative;
  }
  .p4-glow { position: absolute; top: -40px; left: 50%; transform: translateX(-50%); width: 200px; height: 200px; background: radial-gradient(circle, rgba(212,168,84,0.12) 0%, transparent 70%); pointer-events: none; z-index: 1; }
  .p4-header {
    padding: 1.2rem 1.8rem;
    border-bottom: 1px solid rgba(212,168,84,0.3);
    display: flex; align-items: center; justify-content: space-between;
    position: relative; z-index: 2;
  }
  .p4-logo { color: #F2EBD9; font-size: 1.1rem; font-style: italic; }
  .p4-flame { font-size: 1rem; animation: flicker 2s ease-in-out infinite alternate; }
  @keyframes flicker { 0% { opacity: 0.8; } 50% { opacity: 1; transform: scale(1.1); } 100% { opacity: 0.7; } }
  .p4-nav span { color: rgba(212,168,84,0.6); font-size: 0.6rem; letter-spacing: 0.2em; font-family: 'Cinzel', serif; margin-left: 1.2rem; }
  .p4-body { padding: 1.5rem 1.8rem; position: relative; z-index: 2; }
  .p4-label { color: #D4A854; font-size: 0.58rem; letter-spacing: 0.35em; text-transform: uppercase; font-family: 'Cinzel', serif; margin-bottom: 0.6rem; }
  .p4-title { color: #F2EBD9; font-size: 1.85rem; line-height: 1.15; margin-bottom: 0.3rem; font-style: italic; }
  .p4-rule { height: 1px; background: linear-gradient(to right, #D4A854, transparent); margin: 0.6rem 0; }
  .p4-text { color: rgba(242,235,217,0.65); font-size: 0.83rem; line-height: 1.75; font-family: 'EB Garamond', serif; }
  .p4-ornament { text-align: center; color: rgba(212,168,84,0.4); font-size: 1rem; margin: 0.75rem 0; letter-spacing: 0.5em; }
  .p4-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 0.7rem; }
  .p4-card { border: 1px solid rgba(212,168,84,0.15); padding: 0.75rem; background: rgba(212,168,84,0.03); }
  .p4-card-label { color: rgba(212,168,84,0.5); font-size: 0.55rem; letter-spacing: 0.2em; font-family: 'Cinzel', serif; text-transform: uppercase; }
  .p4-card-title { color: rgba(242,235,217,0.8); font-size: 0.82rem; margin-top: 0.2rem; font-style: italic; }

  /* ===================================================
     CONCEPT 5: REGATTA — Yacht Club Classic
  =================================================== */
  .preview-5 {
    background: #F9F7F2;
    font-family: 'Libre Baskerville', serif;
  }
  .p5-stripe { height: 5px; background: repeating-linear-gradient(90deg, #1E2F44 0, #1E2F44 20px, #F9F7F2 20px, #F9F7F2 40px); }
  .p5-header {
    background: #1E2F44;
    padding: 1.1rem 1.8rem;
    display: flex; align-items: center; justify-content: space-between;
  }
  .p5-logo { color: #fff; font-size: 1rem; letter-spacing: 0.12em; text-transform: uppercase; font-family: 'Cinzel', serif; }
  .p5-nav span { color: rgba(255,255,255,0.6); font-size: 0.6rem; letter-spacing: 0.18em; font-family: 'Cinzel', serif; margin-left: 1.2rem; text-transform: uppercase; }
  .p5-red-stripe { height: 3px; background: #B23A2B; }
  .p5-body { padding: 1.4rem 1.8rem; }
  .p5-edition { color: #B23A2B; font-size: 0.6rem; letter-spacing: 0.3em; text-transform: uppercase; font-family: 'Cinzel', serif; margin-bottom: 0.5rem; }
  .p5-title { color: #1E2F44; font-size: 1.85rem; line-height: 1.15; margin-bottom: 0.25rem; }
  .p5-date { color: #8a9aaa; font-size: 0.7rem; font-style: italic; margin-bottom: 0.75rem; }
  .p5-text { color: #2a3545; font-size: 0.83rem; line-height: 1.7; }
  .p5-h-rule { border: none; border-top: 1px solid #1E2F44; margin: 0.85rem 0; opacity: 0.15; }
  .p5-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 0.7rem; }
  .p5-card { border-top: 3px solid #1E2F44; padding-top: 0.6rem; }
  .p5-card-ed { color: #B23A2B; font-size: 0.55rem; letter-spacing: 0.2em; font-family: 'Cinzel', serif; text-transform: uppercase; }
  .p5-card-title { color: #1E2F44; font-size: 0.82rem; margin-top: 0.15rem; }
  .p5-bottom-stripe { height: 5px; background: repeating-linear-gradient(90deg, #1E2F44 0, #1E2F44 20px, #B23A2B 20px, #B23A2B 40px); margin-top: auto; }

  /* ===================================================
     CONCEPT 6: VIA COMO — Italian Lakeside Summer
  =================================================== */
  .preview-6 {
    background: linear-gradient(160deg, #EEF4F7 0%, #F7F3EB 50%, #F2EBE4 100%);
    font-family: 'Cormorant Garamond', serif;
    position: relative;
  }
  .p6-watercolor {
    position: absolute; top: 0; left: 0; right: 0; height: 160px;
    background: linear-gradient(180deg, rgba(111,163,184,0.25) 0%, rgba(200,106,74,0.05) 60%, transparent 100%);
    pointer-events: none;
  }
  .p6-header {
    padding: 1.4rem 1.8rem 1rem;
    display: flex; align-items: center; justify-content: space-between;
    position: relative; z-index: 2;
  }
  .p6-logo { color: #2a5a72; font-size: 1.2rem; font-weight: 300; letter-spacing: 0.06em; font-style: italic; }
  .p6-nav span { color: rgba(42,90,114,0.6); font-size: 0.62rem; letter-spacing: 0.18em; font-family: 'Cinzel', serif; margin-left: 1.2rem; }
  .p6-rule { height: 1px; background: linear-gradient(to right, transparent, #6FA3B8, #C86A4A, transparent); margin: 0 1.8rem; }
  .p6-body { padding: 1.3rem 1.8rem; position: relative; z-index: 2; }
  .p6-tag { color: #C86A4A; font-size: 0.6rem; letter-spacing: 0.3em; text-transform: uppercase; font-family: 'Cinzel', serif; margin-bottom: 0.5rem; }
  .p6-title { color: #1a3a4a; font-size: 1.9rem; line-height: 1.15; font-weight: 300; margin-bottom: 0.2rem; }
  .p6-title em { font-weight: 500; color: #2a5a72; }
  .p6-loc { color: #6FA3B8; font-size: 0.75rem; font-style: italic; margin-bottom: 0.75rem; }
  .p6-text { color: #2a3535; font-size: 0.85rem; line-height: 1.75; }
  .p6-divider { text-align: center; color: #C86A4A; margin: 0.75rem 0; opacity: 0.5; font-size: 0.9rem; letter-spacing: 0.4em; }
  .p6-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 0.7rem; }
  .p6-card { background: rgba(111,163,184,0.08); padding: 0.75rem; border-bottom: 2px solid #C86A4A; }
  .p6-card-loc { color: #6FA3B8; font-size: 0.55rem; letter-spacing: 0.18em; font-family: 'Cinzel', serif; text-transform: uppercase; }
  .p6-card-title { color: #1a3a4a; font-size: 0.83rem; margin-top: 0.2rem; font-style: italic; }

  /* ===================================================
     CONCEPT 7: THE GILT PRESS — High Editorial
  =================================================== */
  .preview-7 {
    background: #FAFAF7;
    font-family: 'Playfair Display', serif;
  }
  .p7-header {
    background: #111;
    padding: 1.2rem 1.8rem;
    text-align: center;
    border-bottom: 3px solid #C9A84C;
  }
  .p7-masthead { color: #fff; font-size: 1.6rem; font-style: italic; letter-spacing: 0.04em; }
  .p7-masthead span { color: #C9A84C; }
  .p7-nav { display: flex; gap: 1.5rem; justify-content: center; margin-top: 0.5rem; }
  .p7-nav span { color: rgba(255,255,255,0.5); font-size: 0.58rem; letter-spacing: 0.22em; font-family: 'Cinzel', serif; text-transform: uppercase; }
  .p7-body { padding: 1.5rem 1.8rem; }
  .p7-featured { border-top: 4px solid #111; padding-top: 0.8rem; margin-bottom: 1rem; }
  .p7-label { color: #C9A84C; font-size: 0.58rem; letter-spacing: 0.3em; font-family: 'Cinzel', serif; text-transform: uppercase; margin-bottom: 0.4rem; }
  .p7-title { color: #111; font-size: 1.9rem; line-height: 1.1; margin-bottom: 0.25rem; }
  .p7-byline { color: #888; font-size: 0.72rem; font-style: italic; margin-bottom: 0.7rem; }
  .p7-text { color: #333; font-size: 0.83rem; line-height: 1.7; font-family: 'EB Garamond', serif; }
  .p7-rule { border: none; border-top: 1px solid #ddd; margin: 0.85rem 0; }
  .p7-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0.7rem; }
