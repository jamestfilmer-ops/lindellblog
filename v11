<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
  background: #ECECEC;
  font-family: 'Josefin Sans', sans-serif;
  color: #1a1208;
  overflow-x: hidden;
}

/* ===== PAGE HEADER ===== */
.page-header {
  background: #0d0d0d;
  padding: 64px 64px 48px;
  position: relative;
  overflow: hidden;
}
.page-header::after {
  content: 'SHORTLIST';
  position: absolute;
  right: -10px;
  top: 50%;
  transform: translateY(-50%);
  font-family: 'Josefin Sans', sans-serif;
  font-size: 110px;
  font-weight: 200;
  letter-spacing: 0.3em;
  color: rgba(255,255,255,0.025);
  white-space: nowrap;
  pointer-events: none;
}
.ph-eyebrow {
  font-size: 9px;
  letter-spacing: 0.55em;
  text-transform: uppercase;
  color: #555;
  margin-bottom: 16px;
}
.ph-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(28px, 4vw, 52px);
  font-weight: 300;
  color: #f0ece4;
  line-height: 1.05;
}
.ph-title em { font-style: italic; color: #c8a96e; }
.ph-sub {
  font-family: 'Cormorant Garamond', serif;
  font-size: 16px;
  font-style: italic;
  color: #444;
  margin-top: 12px;
}
.ph-meta {
  display: flex;
  gap: 32px;
  margin-top: 32px;
  padding-top: 24px;
  border-top: 1px solid rgba(255,255,255,0.06);
}
.ph-meta-item {
  font-size: 8px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: #444;
}
.ph-meta-item span { display: block; color: #777; margin-top: 3px; font-size: 9px; letter-spacing: 0.1em; }

/* ===== SECTION ===== */
.section-head {
  display: flex;
  align-items: center;
  gap: 20px;
  padding: 56px 64px 32px;
}
.section-head hr { flex: 1; border: none; border-top: 1px solid #C8C4BC; }
.sh-label {
  font-size: 9px;
  letter-spacing: 0.5em;
  text-transform: uppercase;
  color: #888;
  white-space: nowrap;
}
.sh-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 11px;
  font-style: italic;
  color: #C0B898;
  white-space: nowrap;
}

/* ===== THEME BLOCK ===== */
.theme-block {
  margin: 0 64px 4px;
  position: relative;
}

.theme-frame {
  width: 100%;
  overflow: hidden;
  position: relative;
  cursor: pointer;
  transition: transform 0.4s cubic-bezier(0.25,0.46,0.45,0.94);
  box-shadow: 0 4px 32px rgba(0,0,0,0.12);
}
.theme-frame:hover { transform: translateY(-3px); box-shadow: 0 16px 56px rgba(0,0,0,0.18); }

.theme-label {
  background: white;
  padding: 16px 24px;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  border-top: 1px solid #E8E4DC;
  gap: 24px;
}
.tl-name {
  font-size: 12px;
  font-weight: 400;
  letter-spacing: 0.12em;
  color: #1a1208;
}
.tl-note {
  font-size: 9px;
  font-weight: 300;
  letter-spacing: 0.1em;
  color: #B0A890;
  margin-top: 2px;
}
.tl-fonts {
  font-size: 8.5px;
  letter-spacing: 0.08em;
  color: #C0B8A8;
  text-align: right;
  line-height: 1.6;
}
.tl-fonts strong { font-weight: 400; color: #888; }

/* ===== VARIANT PAIR ===== */
.variant-pair {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4px;
  margin: 0 64px 4px;
}
.variant-pair .theme-block { margin: 0; }

/* ===== PAGE FOOTER ===== */
.page-footer {
  background: #0d0d0d;
  padding: 48px 64px;
  text-align: center;
  margin-top: 64px;
}
.pf-logo {
  font-family: 'Cormorant Garamond', serif;
  font-size: 22px;
  font-style: italic;
  color: #f0ece4;
  margin-bottom: 10px;
}
.pf-note {
  font-size: 8px;
  letter-spacing: 0.35em;
  text-transform: uppercase;
  color: #444;
}

