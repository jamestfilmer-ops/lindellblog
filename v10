  }
  .theme-card:hover { transform: scale(1.008); z-index: 2; }
  .theme-card:hover .mockup-inner { box-shadow: 0 20px 60px rgba(0,0,0,0.2); }

  .mockup-inner {
    transition: box-shadow 0.4s ease;
    height: 340px;
    overflow: hidden;
    position: relative;
  }

  /* Card label */
  .card-label {
    background: white;
    padding: 12px 20px;
    border-top: 1px solid #e8e0d4;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
