<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: #F0ECE4;
    font-family: 'Josefin Sans', sans-serif;
    color: #1a1208;
    padding: 0;
    overflow-x: hidden;
  }

  /* PAGE HEADER */
  .page-header {
    background: #0d0d0d;
    padding: 72px 64px 56px;
    position: relative;
    overflow: hidden;
  }
  .page-header::before {
    content: 'TISBUT';
