    padding-top: 28px;
    border-top: 1px solid rgba(255,255,255,0.07);
  }
  .hm-item {
    font-size: 9px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #555;
  }
  .hm-item span {
    display: block;
    color: #888;
    margin-top: 4px;
    font-size: 10px;
    letter-spacing: 0.1em;
  }

  /* SECTION BREAKS */
  .section-break {
    padding: 56px 64px 32px;
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .section-break hr { flex: 1; border: none; border-top: 1px solid #ccc8be; }
  .section-break-label {
