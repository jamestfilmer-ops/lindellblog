<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Alpine Writer — CSS Design Guide</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,700;1,500&family=Lora:ital,wght@0,400;0,500;1,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>

/* ============================================================
   ALPINE WRITER — COMPLETE CSS DESIGN SYSTEM
   Generated for Claude prompting & developer handoff
   ============================================================ */

/* ── ROOT TOKENS ─────────────────────────────────────────── */
:root {

  /* Backgrounds — universal, near-white, no hue identity */
  --bg:          #F8F8F6;   /* page background */
  --surface:     #F2F2F0;   /* recessed panels, footers, hovers */
  --surface-deep:#EAEAE7;   /* deepest inset, rarely used */

  /* Borders */
  --border:      #DDE0E2;   /* standard 1px border */
  --border-soft: #E8EAEC;   /* hairline 0.5px dividers */

  /* Blues — the soul of the palette (60/30) */
  --deep:        #042B44;   /* headings, site name */
  --secondary:   #2A4A5C;   /* body prose */
  --teal:        #096B90;   /* mid blue, essay tags */
  --sky:         #A1CCDC;   /* light blue, decorative */
  --steel:       #71B7D5;   /* story tags, secondary accent */
  --midnight:    #08171E;   /* darkest, sparingly */
  --muted:       #7A8C94;   /* metadata, timestamps, hints */

  /* Alpenglow — the 4% accent */
  --glow:        #C8660A;   /* THE accent. use sparingly. */
  --glow-lt:     #FDF2EA;   /* glow background tint */
  --glow-border: #EDD0B4;   /* glow pill borders */

  /* Typography */
  --font-serif:  'Playfair Display', Georgia, 'Times New Roman', serif;
  --font-body:   'Lora', Georgia, serif;
  --font-mono:   'JetBrains Mono', 'Fira Code', monospace;

  /* Spacing scale */
  --space-xs:    8px;
  --space-sm:    14px;
  --space-md:    20px;
  --space-lg:    32px;
  --space-xl:    48px;
  --space-2xl:   72px;

  /* Typography scale */
  --text-xs:     11px;
  --text-sm:     12px;
  --text-base:   14px;
  --text-md:     16px;
  --text-lg:     18px;
  --text-xl:     22px;
  --text-2xl:    28px;
  --text-3xl:    36px;

  /* Reading */
  --measure:     65ch;       /* max line length for prose */
  --line-prose:  1.78;       /* body text line height */
  --line-title:  1.22;       /* heading line height */

  /* Borders & radius */
  --radius-sm:   4px;
  --radius-md:   8px;
  --radius-lg:   12px;
  --radius-pill: 20px;

  /* Border weights */
  --border-hairline: 0.5px;
  --border-fine:     1px;
  --border-rule:     1.5px;
  --border-accent:   2px;
}

/* ── RESET & BASE ────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  font-family: var(--font-body);
  font-size: var(--text-base);
  line-height: var(--line-prose);
  color: var(--secondary);
  background: var(--bg);
  -webkit-font-smoothing: antialiased;
}

/* ── GUIDE CHROME ────────────────────────────────────────── */
.guide-wrap {
  max-width: 960px;
  margin: 0 auto;
  padding: 0 32px 80px;
}

.guide-header {
  padding: 48px 0 36px;
  border-bottom: 1px solid var(--border);
  margin-bottom: 48px;
}

.guide-title {
  font-family: var(--font-serif);
  font-size: var(--text-3xl);
  color: var(--deep);
  line-height: var(--line-title);
  margin-bottom: 8px;
}

.guide-sub {
  font-style: italic;
  font-size: var(--text-base);
  color: var(--muted);
}

.guide-nav {
  display: flex;
  gap: 24px;
  margin-top: 24px;
  flex-wrap: wrap;
}

.guide-nav a {
  font-size: var(--text-xs);
  letter-spacing: 1.2px;
  text-transform: uppercase;
  color: var(--muted);
  text-decoration: none;
}

.guide-nav a:hover { color: var(--deep); }

.section {
  margin-bottom: 64px;
}

.section-title {
  font-family: var(--font-serif);
  font-size: var(--text-xl);
  color: var(--deep);
  margin-bottom: 6px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--border);
}

.section-desc {
  font-size: var(--text-sm);
  color: var(--muted);
  font-style: italic;
  margin-bottom: 24px;
  margin-top: 8px;
}

.subsection {
  margin-bottom: 36px;
}

.subsection-title {
  font-size: var(--text-xs);
  letter-spacing: 1.8px;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 14px;
}

/* ── CODE BLOCKS ─────────────────────────────────────────── */
pre {
  background: var(--midnight);
  color: #A1CCDC;
  font-family: var(--font-mono);
  font-size: 12.5px;
  line-height: 1.7;
  padding: 20px 24px;
  border-radius: var(--radius-md);
  overflow-x: auto;
  margin-bottom: 16px;
  border: 1px solid #0F2A36;
}

pre .comment { color: #4A7A8A; font-style: italic; }
pre .key     { color: #71B7D5; }
pre .val     { color: #E8C97A; }
pre .accent  { color: #C8660A; }
pre .str     { color: #A8D8A8; }

code {
  font-family: var(--font-mono);
  font-size: 12px;
  background: var(--surface);
  color: var(--deep);
  padding: 2px 6px;
  border-radius: 3px;
  border: 1px solid var(--border);
}

/* ── COLOR PALETTE DISPLAY ───────────────────────────────── */
.palette-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10px;
  margin-bottom: 16px;
}

.color-chip {
  border-radius: var(--radius-md);
  overflow: hidden;
  border: 1px solid var(--border);
}

.chip-swatch {
  height: 60px;
}

.chip-info {
  padding: 8px 10px;
  background: var(--bg);
}

.chip-name {
  font-size: 11px;
  font-weight: 500;
  color: var(--deep);
  letter-spacing: .3px;
}

.chip-hex {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--muted);
  margin-top: 2px;
}

.chip-role {
  font-size: 10px;
  color: var(--muted);
  font-style: italic;
  margin-top: 2px;
}

.ratio-bar {
  display: flex;
  height: 36px;
  border-radius: var(--radius-sm);
  overflow: hidden;
  border: 1px solid var(--border);
  margin-bottom: 10px;
}

.ratio-seg {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 10px;
  letter-spacing: .5px;
}

/* ── SPACING DISPLAY ─────────────────────────────────────── */
.space-table {
  width: 100%;
  border-collapse: collapse;
}

.space-table th {
  font-size: var(--text-xs);
  letter-spacing: 1.2px;
  text-transform: uppercase;
  color: var(--muted);
  text-align: left;
  padding: 8px 12px;
  border-bottom: 1px solid var(--border);
  font-weight: 500;
}

.space-table td {
  padding: 10px 12px;
  font-size: var(--text-sm);
  color: var(--secondary);
  border-bottom: 1px solid var(--border-soft);
  vertical-align: middle;
}

.space-table tr:last-child td { border-bottom: none; }

.space-bar-wrap { display: flex; align-items: center; gap: 10px; }

.space-bar {
  background: var(--teal);
  height: 8px;
  border-radius: 2px;
  opacity: .5;
}

.mono { font-family: var(--font-mono); font-size: 11px; color: var(--deep); }

/* ── TYPOGRAPHY DISPLAY ──────────────────────────────────── */
.type-specimen {
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  margin-bottom: 16px;
}

.type-row {
  display: grid;
  grid-template-columns: 160px 1fr 100px;
  align-items: baseline;
  padding: 14px 20px;
  border-bottom: 1px solid var(--border-soft);
  gap: 16px;
}

.type-row:last-child { border-bottom: none; }

.type-label {
  font-size: var(--text-xs);
  letter-spacing: 1.2px;
  text-transform: uppercase;
  color: var(--muted);
}

.type-meta {
  font-size: 11px;
  color: var(--muted);
  font-family: var(--font-mono);
  text-align: right;
}

/* ── BORDER DISPLAY ──────────────────────────────────────── */
.border-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10px;
}

.border-card {
  padding: 16px 18px;
  border-radius: var(--radius-md);
  background: var(--bg);
}

.border-label {
  font-size: var(--text-xs);
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 8px;
}

.border-demo {
  height: 36px;
  border-radius: var(--radius-sm);
  margin-bottom: 8px;
}

.border-spec { font-family: var(--font-mono); font-size: 11px; color: var(--deep); }
.border-use  { font-size: 11px; font-style: italic; color: var(--muted); margin-top: 4px; }

/* ── RADIUS DISPLAY ──────────────────────────────────────── */
.radius-row {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}

.radius-chip {
  background: var(--surface);
  border: 1px solid var(--border);
  padding: 18px 24px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  flex: 1;
  min-width: 100px;
}

.radius-box {
  width: 48px;
  height: 48px;
  background: var(--teal);
  opacity: .7;
}

.radius-name { font-size: 11px; color: var(--deep); font-weight: 500; }
.radius-val  { font-family: var(--font-mono); font-size: 11px; color: var(--muted); }
.radius-use  { font-size: 10px; font-style: italic; color: var(--muted); text-align: center; }

/* ── COMPONENT DEMOS ─────────────────────────────────────── */
.demo-frame {
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  margin-bottom: 16px;
}

/* ── ACTUAL SITE COMPONENTS ──────────────────────────────── */

/* Progress bar */
.progress-bar { height: 3px; background: var(--border); width: 100%; }
.progress-fill { height: 3px; background: var(--glow); width: 55%; }

/* Nav */
.site-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 28px;
  background: var(--bg);
  border-bottom: 1px solid var(--border);
}

.site-name {
  font-family: var(--font-serif);
  font-size: var(--text-xl);
  color: var(--deep);
}

.site-tagline {
  font-style: italic;
  font-size: var(--text-sm);
  color: var(--muted);
  font-family: var(--font-body);
  margin-left: 8px;
}

.nav-links {
  display: flex;
  gap: 22px;
  align-items: center;
}

.nav-link {
  font-size: var(--text-sm);
  color: var(--muted);
  letter-spacing: .4px;
  cursor: pointer;
  text-decoration: none;
}

.nav-link:hover { color: var(--deep); }

.mood-pill {
  font-size: var(--text-xs);
  color: var(--glow);
  background: var(--glow-lt);
  border: 1px solid var(--glow-border);
  padding: 4px 11px;
  border-radius: var(--radius-pill);
  letter-spacing: .3px;
}

/* Genre tabs */
.genre-tabs {
  display: flex;
  border-bottom: 1px solid var(--border);
  background: var(--bg);
}

.genre-tab {
  padding: 10px 18px;
  font-size: var(--text-xs);
  letter-spacing: .8px;
  text-transform: uppercase;
  color: var(--muted);
  cursor: pointer;
  border-bottom: 2px solid transparent;
  margin-bottom: -1px;
  font-family: var(--font-body);
  transition: all .2s;
}

.genre-tab:hover { color: var(--deep); }

.genre-tab.active {
  color: var(--deep);
  border-bottom-color: var(--glow);
}

/* Genre tags inline */
.tag-essay  { color: var(--teal); }
.tag-story  { color: var(--steel); }
.tag-poem   { color: var(--glow); }

/* Genre tag element */
.genre-tag-label {
  font-size: var(--text-xs);
  letter-spacing: 2px;
  text-transform: uppercase;
  font-family: var(--font-body);
}

/* Article card */
.article-card {
  padding: 20px 22px;
  background: var(--bg);
  border-right: 1px solid var(--border);
  cursor: pointer;
  transition: background .15s;
}

.article-card:hover { background: var(--surface); }

.card-title {
  font-family: var(--font-serif);
  font-size: var(--text-md);
  line-height: var(--line-title);
  color: var(--deep);
  margin-bottom: 7px;
}

.card-excerpt {
  font-size: var(--text-sm);
  font-style: italic;
  color: var(--secondary);
  line-height: 1.65;
  margin-bottom: 10px;
}

.card-meta {
  font-size: var(--text-xs);
  color: var(--muted);
  letter-spacing: .3px;
}

.card-note {
  font-size: 10px;
  font-style: italic;
  color: var(--muted);
}

/* Honest badge */
.honest-badge {
  font-size: 10px;
  background: var(--glow-lt);
  border: 1px solid var(--glow-border);
  padding: 3px 9px;
  border-radius: var(--radius-pill);
  color: var(--glow);
  font-style: italic;
}

/* Pull quote */
.pull-quote {
  font-family: var(--font-serif);
  font-style: italic;
  font-size: var(--text-lg);
  line-height: 1.6;
  color: var(--deep);
  border-left: 2px solid var(--glow);
  padding-left: 16px;
  border-radius: 0;
}

.pull-attr {
  font-size: var(--text-xs);
  color: var(--muted);
  margin-top: 10px;
  letter-spacing: .3px;
}

/* Newsletter footer */
.nl-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 28px;
  background: var(--surface);
  border-top: 1px solid var(--border);
}

.nl-input {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  padding: 6px 12px;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  background: var(--bg);
  color: var(--deep);
  width: 170px;
}

.nl-input:focus {
  outline: none;
  border-color: var(--teal);
  box-shadow: 0 0 0 3px rgba(9, 107, 144, .1);
}

.nl-btn {
  font-family: var(--font-body);
  font-size: var(--text-xs);
  letter-spacing: .8px;
  text-transform: uppercase;
  padding: 7px 14px;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  background: transparent;
  color: var(--deep);
  cursor: pointer;
  transition: background .15s;
}

.nl-btn:hover { background: var(--surface-deep); }

/* Reading progress */
.reading-progress {
  height: 3px;
  background: var(--glow);
  width: 0%;
  transition: width .1s linear;
}

/* Article body */
.article-body {
  max-width: var(--measure);
  font-size: var(--text-md);
  line-height: var(--line-prose);
  color: var(--secondary);
}

.article-body p { margin-bottom: 1.4em; }

.article-body h2 {
  font-family: var(--font-serif);
  font-size: var(--text-2xl);
  color: var(--deep);
  line-height: var(--line-title);
  margin: 2em 0 .6em;
}

.article-body blockquote {
  border-left: 2px solid var(--glow);
  padding-left: 20px;
  margin: 2em 0;
  border-radius: 0;
}

.article-body blockquote p {
  font-family: var(--font-serif);
  font-style: italic;
  font-size: var(--text-lg);
  color: var(--deep);
  margin-bottom: 0;
}

/* Skeleton loading */
.skeleton {
  background: var(--surface);
  border-radius: 3px;
  animation: shimmer 1.4s ease-in-out infinite;
}

@keyframes shimmer {
  0%   { opacity: .5; }
  50%  { opacity: 1; }
  100% { opacity: .5; }
}

/* Scroll fade animation */
.fade-up {
  opacity: 0;
  transform: translateY(18px);
  transition: opacity .45s ease, transform .45s ease;
}

.fade-up.visible {
  opacity: 1;
  transform: translateY(0);
}

/* Stagger children */
.fade-up:nth-child(1) { transition-delay: .05s; }
.fade-up:nth-child(2) { transition-delay: .15s; }
.fade-up:nth-child(3) { transition-delay: .25s; }

/* Sticky nav (shrink on scroll) */
.site-nav.scrolled {
  padding-top: 8px;
  padding-bottom: 8px;
  transition: padding .3s ease;
}

/* ── UTILITY CLASSES ─────────────────────────────────────── */
.text-deep      { color: var(--deep); }
.text-secondary { color: var(--secondary); }
.text-muted     { color: var(--muted); }
.text-glow      { color: var(--glow); }
.text-teal      { color: var(--teal); }
.text-steel     { color: var(--steel); }

.serif { font-family: var(--font-serif); }
.italic { font-style: italic; }
.caps { text-transform: uppercase; letter-spacing: 1.5px; font-size: .85em; }

.bg-surface { background: var(--surface); }
.bg-glow-lt { background: var(--glow-lt); }

/* ── GUIDE LAYOUT HELPERS ────────────────────────────────── */
.two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.three-col { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; }

.rule { border: none; border-top: 1px solid var(--border); margin: 48px 0; }

.note-box {
  background: var(--glow-lt);
  border: 1px solid var(--glow-border);
  border-radius: var(--radius-md);
  padding: 14px 18px;
  font-size: var(--text-sm);
  color: var(--secondary);
  margin-bottom: 16px;
}

.note-box strong { color: var(--glow); }

.do-dont {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  margin-bottom: 16px;
}

.do-box, .dont-box {
  padding: 14px 16px;
  border-radius: var(--radius-md);
  font-size: var(--text-sm);
}

.do-box {
  background: #F0F7F0;
  border: 1px solid #C0DBC0;
}

.dont-box {
  background: #FDF0F0;
  border: 1px solid #DCC0C0;
}

.do-label  { font-size: var(--text-xs); letter-spacing: 1px; text-transform: uppercase; color: #4A7A4A; margin-bottom: 6px; }
.dont-label{ font-size: var(--text-xs); letter-spacing: 1px; text-transform: uppercase; color: #7A4A4A; margin-bottom: 6px; }

</style>
</head>
