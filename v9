  background: var(--surface);
  border-radius: 3px;
  animation: shimmer 1.4s ease-in-out infinite;
}
<span class="key">@keyframes shimmer</span> {
  0%   { opacity: .5; }
  50%  { opacity: 1; }
  100% { opacity: .5; }
}</pre>
    </div>
  </section>

  <hr class="rule">

  <!-- ── 6. ANIMATION ──────────────────────────────────────── -->
  <section class="section" id="animation">
    <div class="section-title">6. Animation</div>
    <div class="section-desc">Three animation patterns only. Each is purposeful. None are decorative.</div>

    <div class="subsection">
      <div class="subsection-title">Scroll fade-up — card entrances</div>
      <pre><span class="key">.fade-up</span> {
  opacity: 0;
  transform: translateY(18px);
  transition: opacity .45s ease, transform .45s ease;
}
<span class="key">.fade-up.visible</span> { opacity: 1; transform: translateY(0); }

<span class="comment">/* Stagger children */</span>
<span class="key">.fade-up:nth-child(1)</span> { transition-delay: .05s; }
<span class="key">.fade-up:nth-child(2)</span> { transition-delay: .15s; }
<span class="key">.fade-up:nth-child(3)</span> { transition-delay: .25s; }

<span class="comment">/* Trigger with IntersectionObserver */</span>
<span class="str">const</span> io = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add(<span class="str">'visible'</span>); });
}, { threshold: 0.1 });
document.querySelectorAll(<span class="str">'.fade-up'</span>).forEach(el => io.observe(el));</pre>
    </div>

    <div class="subsection">
      <div class="subsection-title">Reading progress bar</div>
      <pre><span class="comment">/* HTML: sits at very top of page, above nav */</span>
&lt;div style=<span class="str">"height:3px;background:var(--border);"</span>&gt;
  &lt;div id=<span class="str">"reading-progress"</span> style=<span class="str">"height:3px;background:var(--glow);width:0%;transition:width .1s linear;"</span>&gt;&lt;/div&gt;
&lt;/div&gt;

<span class="comment">/* JS */</span>
window.addEventListener(<span class="str">'scroll'</span>, () => {
  <span class="str">const</span> doc = document.documentElement;
  <span class="str">const</span> pct = (doc.scrollTop / (doc.scrollHeight - doc.clientHeight)) * 100;
  document.getElementById(<span class="str">'reading-progress'</span>).style.width = pct + <span class="str">'%'</span>;
});</pre>
    </div>

    <div class="subsection">
      <div class="subsection-title">Sticky nav shrink on scroll</div>
      <pre><span class="key">.site-nav</span> { padding: 14px 28px; transition: padding .3s ease; }
<span class="key">.site-nav.scrolled</span> { padding: 8px 28px; }

<span class="comment">/* JS */</span>
window.addEventListener(<span class="str">'scroll'</span>, () => {
  document.querySelector(<span class="str">'.site-nav'</span>).classList.toggle(<span class="str">'scrolled'</span>, window.scrollY > 60);
});</pre>
    </div>
  </section>

  <hr class="rule">

  <!-- ── 7. DO & DON'T ─────────────────────────────────────── -->
  <section class="section" id="do-dont">
    <div class="section-title">7. Do & don't</div>
    <div class="section-desc">The rules that protect the personality of the design.</div>

    <div class="do-dont">
      <div class="do-box">
        <div class="do-label">Do</div>
        Use <code>--bg</code> (#F8F8F6) for the page — it disappears
      </div>
      <div class="dont-box">
        <div class="dont-label">Don't</div>
        Use a blue-tinted background — the palette fights itself
      </div>
    </div>
    <div class="do-dont">
      <div class="do-box">
        <div class="do-label">Do</div>
        Use <code>--glow</code> in exactly 4 places: progress bar, featured genre tag, pull-quote border, mood pill
      </div>
      <div class="dont-box">
        <div class="dont-label">Don't</div>
        Use the orange on links, hover states, or decorative elements — it loses its meaning
      </div>
    </div>
    <div class="do-dont">
      <div class="do-box">
        <div class="do-label">Do</div>
        Keep article body at <code>max-width: 65ch</code> with <code>line-height: 1.78</code>
      </div>
      <div class="dont-box">
        <div class="dont-label">Don't</div>
        Let prose span full width — reading lines over 75ch cause fatigue
      </div>
    </div>
    <div class="do-dont">
      <div class="do-box">
        <div class="do-label">Do</div>
        Use <code>border-radius: 0</code> on pull-quote left borders — rounded corners with single-sided borders look wrong
      </div>
      <div class="dont-box">
        <div class="dont-label">Don't</div>
        Round a border that only exists on one side
      </div>
    </div>
    <div class="do-dont">
      <div class="do-box">
        <div class="do-label">Do</div>
        Use Playfair Display for all titles — it's the "face" of the site
      </div>
      <div class="dont-box">
        <div class="dont-label">Don't</div>
        Use system fonts or sans-serifs in headings — the literary register collapses
      </div>
    </div>
    <div class="do-dont">
      <div class="do-box">
        <div class="do-label">Do</div>
        Keep hover states as <code>background: var(--surface)</code> — a 3% shift is enough
      </div>
      <div class="dont-box">
        <div class="dont-label">Don't</div>
        Add drop shadows or color shifts on hover — it breaks the flat calm of the palette
      </div>
    </div>
  </section>

  <hr class="rule">

  <!-- ── 8. FULL CSS ────────────────────────────────────────── -->
  <section class="section" id="full-css">
    <div class="section-title">8. Full :root token block</div>
    <div class="section-desc">Paste this into the top of your stylesheet. Every component in this guide references these variables.</div>
    <pre><span class="key">:root</span> {

  <span class="comment">/* ── Backgrounds ─────────────────────────────── */</span>
  <span class="key">--bg</span>:          <span class="val">#F8F8F6</span>;   <span class="comment">/* page — near-white, no hue */</span>
  <span class="key">--surface</span>:     <span class="val">#F2F2F0</span>;   <span class="comment">/* panels, footers, card hovers */</span>
  <span class="key">--surface-deep</span>:<span class="val">#EAEAE7</span>;   <span class="comment">/* deepest inset, rarely used */</span>

  <span class="comment">/* ── Borders ──────────────────────────────────── */</span>
  <span class="key">--border</span>:      <span class="val">#DDE0E2</span>;   <span class="comment">/* standard 1px border */</span>
  <span class="key">--border-soft</span>: <span class="val">#E8EAEC</span>;   <span class="comment">/* hairline 0.5px dividers */</span>

  <span class="comment">/* ── Blues ────────────────────────────────────── */</span>
  <span class="key">--deep</span>:        <span class="val">#042B44</span>;   <span class="comment">/* headings, site name */</span>
  <span class="key">--secondary</span>:   <span class="val">#2A4A5C</span>;   <span class="comment">/* body prose */</span>
  <span class="key">--teal</span>:        <span class="val">#096B90</span>;   <span class="comment">/* essay tags, mid blue */</span>
  <span class="key">--sky</span>:         <span class="val">#A1CCDC</span>;   <span class="comment">/* decorative only */</span>
  <span class="key">--steel</span>:       <span class="val">#71B7D5</span>;   <span class="comment">/* story tags */</span>
  <span class="key">--midnight</span>:    <span class="val">#08171E</span>;   <span class="comment">/* code backgrounds */</span>
  <span class="key">--muted</span>:       <span class="val">#7A8C94</span>;   <span class="comment">/* metadata, timestamps */</span>

  <span class="comment">/* ── Alpenglow (4% — use sparingly) ───────────── */</span>
  <span class="key">--glow</span>:        <span class="val">#C8660A</span>;   <span class="comment">/* progress bar, featured tag, pull-quote border, mood pill */</span>
  <span class="key">--glow-lt</span>:     <span class="val">#FDF2EA</span>;   <span class="comment">/* pill backgrounds */</span>
  <span class="key">--glow-border</span>: <span class="val">#EDD0B4</span>;   <span class="comment">/* pill borders */</span>

  <span class="comment">/* ── Typography ───────────────────────────────── */</span>
  <span class="key">--font-serif</span>:  <span class="val">'Playfair Display'</span>, Georgia, serif;
  <span class="key">--font-body</span>:   <span class="val">'Lora'</span>, Georgia, serif;
  <span class="key">--font-mono</span>:   <span class="val">'JetBrains Mono'</span>, monospace;

  <span class="comment">/* ── Type scale ───────────────────────────────── */</span>
  <span class="key">--text-xs</span>:  <span class="val">11px</span>;
  <span class="key">--text-sm</span>:  <span class="val">12px</span>;
  <span class="key">--text-base</span>:<span class="val">14px</span>;
  <span class="key">--text-md</span>:  <span class="val">16px</span>;
  <span class="key">--text-lg</span>:  <span class="val">18px</span>;
  <span class="key">--text-xl</span>:  <span class="val">22px</span>;
  <span class="key">--text-2xl</span>: <span class="val">28px</span>;
  <span class="key">--text-3xl</span>: <span class="val">36px</span>;

  <span class="comment">/* ── Spacing ──────────────────────────────────── */</span>
  <span class="key">--space-xs</span>:  <span class="val">8px</span>;
  <span class="key">--space-sm</span>:  <span class="val">14px</span>;
  <span class="key">--space-md</span>:  <span class="val">20px</span>;
  <span class="key">--space-lg</span>:  <span class="val">32px</span>;
  <span class="key">--space-xl</span>:  <span class="val">48px</span>;
  <span class="key">--space-2xl</span>: <span class="val">72px</span>;

  <span class="comment">/* ── Reading ──────────────────────────────────── */</span>
  <span class="key">--measure</span>:     <span class="val">65ch</span>;    <span class="comment">/* max prose line length */</span>
  <span class="key">--line-prose</span>:  <span class="val">1.78</span>;   <span class="comment">/* body line height */</span>
  <span class="key">--line-title</span>:  <span class="val">1.22</span>;   <span class="comment">/* heading line height */</span>

  <span class="comment">/* ── Radius ───────────────────────────────────── */</span>
  <span class="key">--radius-sm</span>:   <span class="val">4px</span>;    <span class="comment">/* inputs, buttons */</span>
  <span class="key">--radius-md</span>:   <span class="val">8px</span>;    <span class="comment">/* cards, code blocks */</span>
  <span class="key">--radius-lg</span>:   <span class="val">12px</span>;   <span class="comment">/* outer frames */</span>
  <span class="key">--radius-pill</span>: <span class="val">20px</span>;   <span class="comment">/* mood pill, badges */</span>
}</pre>
  </section>

</div>
</body>
</html>
