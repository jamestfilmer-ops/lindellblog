<div class="guide-wrap">

  <!-- HEADER -->
  <div class="guide-header">
    <div class="guide-title">Alpine Writer — CSS Design Guide</div>
    <div class="guide-sub">Complete token reference & component library for Claude prompting and developer handoff</div>
    <nav class="guide-nav">
      <a href="#palette">Color</a>
      <a href="#typography">Typography</a>
      <a href="#spacing">Spacing</a>
      <a href="#borders">Borders & Radius</a>
      <a href="#components">Components</a>
      <a href="#animation">Animation</a>
      <a href="#do-dont">Do & Don't</a>
      <a href="#full-css">Full CSS</a>
    </nav>
  </div>


  <!-- ── 1. COLOR ─────────────────────────────────────────── -->
  <section class="section" id="palette">
    <div class="section-title">1. Color palette</div>
    <div class="section-desc">Built from an alpine photograph — deep water blues with a single moment of alpenglow orange. Backgrounds are universal near-whites with no hue identity of their own.</div>

    <div class="subsection">
      <div class="subsection-title">60 / 30 / 10 + 4% accent ratio</div>
      <div class="ratio-bar">
        <div class="ratio-seg" style="flex:6;background:#F8F8F6;color:#7A8C94;border-right:1px solid #DDE0E2;">60% bg</div>
        <div class="ratio-seg" style="flex:3;background:#096B90;color:#A1CCDC;">30% blue</div>
        <div class="ratio-seg" style="flex:1;background:#042B44;color:#71B7D5;">10%</div>
        <div class="ratio-seg" style="flex:.4;background:#C8660A;color:#FDF2EA;font-size:9px;">4%</div>
      </div>
    </div>

    <div class="subsection">
      <div class="subsection-title">Background tokens — near-white, no hue</div>
      <div class="palette-grid" style="grid-template-columns:repeat(3,1fr);">
        <div class="color-chip">
          <div class="chip-swatch" style="background:#F8F8F6;border-bottom:1px solid #DDE0E2;"></div>
          <div class="chip-info">
            <div class="chip-name">--bg</div>
            <div class="chip-hex">#F8F8F6</div>
            <div class="chip-role">Page background</div>
          </div>
        </div>
        <div class="color-chip">
          <div class="chip-swatch" style="background:#F2F2F0;border-bottom:1px solid #DDE0E2;"></div>
          <div class="chip-info">
            <div class="chip-name">--surface</div>
            <div class="chip-hex">#F2F2F0</div>
            <div class="chip-role">Panels, footers, hovers</div>
          </div>
        </div>
        <div class="color-chip">
          <div class="chip-swatch" style="background:#EAEAE7;border-bottom:1px solid #DDE0E2;"></div>
          <div class="chip-info">
            <div class="chip-name">--surface-deep</div>
            <div class="chip-hex">#EAEAE7</div>
            <div class="chip-role">Deepest inset, rarely</div>
          </div>
        </div>
      </div>
    </div>

    <div class="subsection">
      <div class="subsection-title">Blue family — the body of the palette</div>
      <div class="palette-grid">
        <div class="color-chip">
