<style>
/* ═══════════════════════════════════════════
   TOKENS — British Racing Green + Gold
═══════════════════════════════════════════ */
:root {
  --bg:       #FDFCFA;
  --bg-dark:  #0C1F10;
  --bg-card:  #F4F5F0;
  --bg-hover: #EBF0E6;
  --green:    #1B4332;
  --gold:     #B8A050;
  --ink:      #0C1A0E;
  --mid:      #7A826E;
  --border:   #D8E0CC;
  --sidebar:  #F2F5EE;
}

/* ═══════════════════════════════════════════
   RESET
═══════════════════════════════════════════ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
  background: var(--bg);
  color: var(--ink);
  font-family: 'Cormorant Garamond', serif;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}

/* ═══════════════════════════════════════════
   SCROLL REVEAL
═══════════════════════════════════════════ */
.reveal {
  opacity: 0;
  transform: translateY(28px);
  transition: opacity 0.85s cubic-bezier(0.25, 0.46, 0.45, 0.94),
              transform 0.85s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}
.reveal.visible        { opacity: 1; transform: translateY(0); }
.reveal-delay-1        { transition-delay: 0.12s; }
.reveal-delay-2        { transition-delay: 0.24s; }
.reveal-delay-3        { transition-delay: 0.36s; }

/* ═══════════════════════════════════════════
   NAVIGATION
═══════════════════════════════════════════ */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 200;
  height: 62px;
  background: var(--bg);
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 52px;
  transition: box-shadow 0.3s ease;
}
nav.scrolled {
  box-shadow: 0 2px 28px rgba(12, 31, 16, 0.07);
}
.nav-green-bar {
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 4px;
  background: var(--green);
}

.nav-logo {
  display: flex;
  flex-direction: column;
  gap: 2px;
  text-decoration: none;
  cursor: pointer;
}
.nav-logo-main {
  font-family: 'Cinzel', serif;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.2em;
  color: var(--ink);
  line-height: 1;
}
.nav-logo-sub {
  font-family: 'Josefin Sans', sans-serif;
  font-size: 7px;
  font-weight: 300;
  letter-spacing: 0.38em;
  text-transform: uppercase;
  color: var(--mid);
  line-height: 1;
}

.nav-links {
  display: flex;
  gap: 36px;
  list-style: none;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}
.nav-links a {
  font-family: 'Josefin Sans', sans-serif;
  font-size: 9px;
  font-weight: 300;
  letter-spacing: 0.38em;
  text-transform: uppercase;
  color: var(--ink);
  text-decoration: none;
  transition: color 0.2s;
  position: relative;
  padding-bottom: 3px;
}
.nav-links a::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 1px;
  background: var(--green);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}
.nav-links a:hover         { color: var(--green); }
.nav-links a:hover::after  { transform: scaleX(1); }

.nav-right {
  font-family: 'Josefin Sans', sans-serif;
  font-size: 8px;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--mid);
}

/* ═══════════════════════════════════════════
   HERO
═══════════════════════════════════════════ */
.hero {
  padding-top: 62px;
  min-height: 100vh;
  display: grid;
  grid-template-columns: 1fr 1fr;
}

/* Left — dark panel */
.hero-left {
  background: var(--bg-dark);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 80px 64px;
  position: relative;
  overflow: hidden;
  animation: slideInLeft 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
}
@keyframes slideInLeft {
  from { opacity: 0; transform: translateX(-36px); }
  to   { opacity: 1; transform: translateX(0); }
}

/* Ghosted italic background letter */
.hero-bg-glyph {
  position: absolute;
  right: -20px;
  top: 50%;
  transform: translateY(-50%);
  font-family: 'Cormorant Garamond', serif;
  font-size: 400px;
  font-weight: 300;
  font-style: italic;
  color: rgba(27, 67, 50, 0.07);
  line-height: 1;
  pointer-events: none;
  user-select: none;
}

.hero-tag {
  font-family: 'Josefin Sans', sans-serif;
  font-size: 8px;
  font-weight: 300;
  letter-spacing: 0.55em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 20px;
  display: flex;
  align-items: center;
  gap: 14px;
  animation: fadeUp 1.2s 0.15s both;
}
.hero-tag::before {
  content: '';
  display: block;
  width: 28px;
  height: 1px;
  background: var(--gold);
}

.hero-title {
  font-size: clamp(32px, 3.8vw, 54px);
  font-weight: 300;
  font-style: italic;
  color: #F7F4EF;
  line-height: 1.08;
  margin-bottom: 24px;
  animation: fadeUp 1.3s 0.25s both;
}

.hero-excerpt {
  font-size: 15px;
  font-weight: 300;
  color: rgba(247, 244, 239, 0.42);
  line-height: 1.8;
  max-width: 420px;
  margin-bottom: 44px;
  animation: fadeUp 1.3s 0.35s both;
}

.hero-cta {
  display: inline-flex;
  align-items: center;
  gap: 18px;
  text-decoration: none;
  animation: fadeUp 1.3s 0.45s both;
  width: fit-content;
}
.hero-cta-label {
  font-family: 'Josefin Sans', sans-serif;
  font-size: 8px;
  font-weight: 300;
  letter-spacing: 0.52em;
  text-transform: uppercase;
  color: rgba(247, 244, 239, 0.45);
  border-bottom: 1px solid rgba(184, 160, 80, 0.4);
  padding-bottom: 3px;
  transition: color 0.3s, border-color 0.3s, letter-spacing 0.3s;
}
.hero-cta:hover .hero-cta-label {
  color: #F7F4EF;
  border-color: var(--gold);
  letter-spacing: 0.68em;
}
.hero-cta-line {
  width: 22px;
  height: 1px;
  background: rgba(184, 160, 80, 0.4);
  transition: width 0.3s, background 0.3s;
}
.hero-cta:hover .hero-cta-line {
  width: 38px;
  background: var(--gold);
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* Right — sidebar */
.hero-right {
  background: var(--sidebar);
  display: flex;
  flex-direction: column;
  border-left: 1px solid var(--border);
  animation: slideInRight 1.3s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0.1s both;
}
@keyframes slideInRight {
  from { opacity: 0; transform: translateX(24px); }
  to   { opacity: 1; transform: translateX(0); }
}

.sidebar-head {
  padding: 32px 48px;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  gap: 12px;
}
.sh-pip {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--green);
}
.sh-label {
  font-family: 'Josefin Sans', sans-serif;
  font-size: 8px;
  font-weight: 300;
  letter-spacing: 0.5em;
  text-transform: uppercase;
  color: var(--mid);
}

.sidebar-item {
  flex: 1;
  padding: 28px 48px;
  border-bottom: 1px solid var(--border);
  cursor: pointer;
  transition: background 0.25s ease, padding-left 0.28s ease;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.sidebar-item:hover          { background: #E3EBD9; padding-left: 58px; }
.sidebar-item:hover .si-title { color: var(--green); }

.si-type {
  font-family: 'Josefin Sans', sans-serif;
  font-size: 7px;
  font-weight: 300;
  letter-spacing: 0.52em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 8px;
}
.si-title {
  font-size: 21px;
  font-weight: 400;
  font-style: italic;
  line-height: 1.2;
  color: var(--ink);
  transition: color 0.25s;
  margin-bottom: 6px;
}
.si-meta {
  font-family: 'Josefin Sans', sans-serif;
  font-size: 8px;
  font-weight: 200;
  letter-spacing: 0.22em;
  color: var(--mid);
}

/* ═══════════════════════════════════════════
   GREEN RULE
═══════════════════════════════════════════ */
.green-rule {
  height: 3px;
  background: var(--green);
}

/* ═══════════════════════════════════════════
   SECTION HEADER
═══════════════════════════════════════════ */
.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 44px 52px 30px;
}
.section-head h2 {
  font-family: 'Josefin Sans', sans-serif;
  font-size: 9px;
  font-weight: 400;
  letter-spacing: 0.52em;
  text-transform: uppercase;
  color: var(--ink);
}
.section-head a {
  font-family: 'Josefin Sans', sans-serif;
  font-size: 8px;
  font-weight: 300;
  letter-spacing: 0.32em;
  text-transform: uppercase;
  color: var(--gold);
  text-decoration: none;
  transition: letter-spacing 0.3s, color 0.2s;
}
.section-head a:hover {
  letter-spacing: 0.48em;
  color: var(--green);
}

/* ═══════════════════════════════════════════
   ARTICLE GRID
═══════════════════════════════════════════ */
.article-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--border);
  margin: 0 52px;
}

.article-card {
  background: var(--bg-card);
  padding: 36px 32px;
  cursor: pointer;
  transition: background 0.3s ease;
  position: relative;
  overflow: hidden;
}
/* Bottom BRG underline sweep on hover */
.article-card::before {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 2px;
  background: var(--green);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.42s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}
.article-card:hover              { background: var(--bg-hover); }
.article-card:hover::before      { transform: scaleX(1); }
.article-card:hover .ac-title    { color: var(--green); }

.ac-num {
  font-family: 'Josefin Sans', sans-serif;
  font-size: 9px;
  font-weight: 300;
  letter-spacing: 0.22em;
  color: var(--border);
  margin-bottom: 20px;
}
.ac-type {
  font-family: 'Josefin Sans', sans-serif;
  font-size: 7px;
  font-weight: 300;
  letter-spacing: 0.52em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 10px;
  opacity: 0.9;
}
.ac-title {
  font-size: 24px;
  font-weight: 300;
  font-style: italic;
  line-height: 1.2;
  margin-bottom: 14px;
  transition: color 0.25s;
  color: var(--ink);
}
.ac-excerpt {
  font-size: 13px;
  font-weight: 300;
  color: #808878;
  line-height: 1.78;
  margin-bottom: 20px;
}
.ac-read {
  font-family: 'Josefin Sans', sans-serif;
  font-size: 8px;
  font-weight: 300;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--mid);
}

/* Poem card — slightly tinted */
.article-card.poem-card {
  background: #E8EEE0;
}
.article-card.poem-card:hover {
  background: #DDE7D4;
}
.article-card.poem-card .ac-title {
  font-size: 28px;
}
.article-card.poem-card .ac-excerpt {
  font-style: italic;
  color: #9AA08A;
  font-size: 14px;
}

/* ═══════════════════════════════════════════
   MASTHEAD BAND
═══════════════════════════════════════════ */
.masthead-band {
  margin-top: 68px;
  background: var(--bg-dark);
  padding: 56px 64px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 40px;
}
.mb-wordmark {
  font-family: 'Cinzel', serif;
  font-size: 10px;
  letter-spacing: 0.52em;
  text-transform: uppercase;
  color: #2A3A2E;
  white-space: nowrap;
}
.mb-quote {
  font-size: 22px;
  font-style: italic;
  font-weight: 300;
  color: rgba(247, 244, 239, 0.55);
  line-height: 1.45;
  text-align: center;
  max-width: 520px;
  flex: 1;
}
.mb-quote em {
  color: var(--gold);
  font-style: normal;
}
.mb-meta {
  font-family: 'Josefin Sans', sans-serif;
  font-size: 8px;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: #333D2E;
  white-space: nowrap;
  text-align: right;
  line-height: 2;
}

/* ═══════════════════════════════════════════
   FOOTER
═══════════════════════════════════════════ */
footer {
  padding: 40px 52px;
  border-top: 1px solid var(--border);
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 0;
}
.f-logo {
  font-family: 'Cinzel', serif;
  font-size: 12px;
  letter-spacing: 0.26em;
  color: var(--ink);
  cursor: pointer;
}
.f-logo span { color: var(--green); }
.f-copy {
  font-family: 'Josefin Sans', sans-serif;
  font-size: 8px;
  font-weight: 300;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--mid);
}

/* ═══════════════════════════════════════════
   PAGE SWITCHING
═══════════════════════════════════════════ */
.home-page.hidden  { display: none; }
.article-page      { display: none; }
.article-page.active { display: block; }

/* ═══════════════════════════════════════════
   ARTICLE NAVIGATION
═══════════════════════════════════════════ */
.article-nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 200;
  height: 62px;
  background: var(--bg);
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 52px;
}
.article-nav .nav-green-bar {
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 4px;
  background: var(--green);
}

.back-btn {
  font-family: 'Josefin Sans', sans-serif;
  font-size: 8px;
  font-weight: 300;
  letter-spacing: 0.38em;
  text-transform: uppercase;
  color: var(--mid);
  cursor: pointer;
  background: none;
  border: none;
  transition: color 0.2s;
  padding: 0;
  display: flex;
  align-items: center;
  gap: 10px;
}
.back-btn::before { content: '←'; font-size: 13px; }
.back-btn:hover   { color: var(--green); }

/* ═══════════════════════════════════════════
   ARTICLE HERO
═══════════════════════════════════════════ */
.art-hero {
  background: var(--bg-dark);
  padding: 104px 64px 80px;
  position: relative;
  overflow: hidden;
}
.art-hero-glyph {
  position: absolute;
  right: -10px;
  top: 50%;
  transform: translateY(-50%);
  font-family: 'Cormorant Garamond', serif;
  font-size: 340px;
  font-weight: 300;
  font-style: italic;
  color: rgba(27, 67, 50, 0.055);
  line-height: 1;
  pointer-events: none;
  user-select: none;
}
.art-type-tag {
  font-family: 'Josefin Sans', sans-serif;
  font-size: 8px;
  font-weight: 300;
  letter-spacing: 0.62em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 28px;
  display: flex;
  align-items: center;
  gap: 14px;
  animation: fadeUp 0.9s both;
}
.art-type-tag::before {
  content: '';
  display: block;
  width: 28px;
  height: 1px;
  background: var(--gold);
}

.art-title {
  font-size: clamp(36px, 5vw, 72px);
  font-weight: 300;
  font-style: italic;
  color: #F7F4EF;
  line-height: 1.05;
  max-width: 800px;
  margin-bottom: 32px;
  animation: fadeUp 1s 0.1s both;
}
.art-dek {
  font-size: 18px;
  font-weight: 300;
  font-style: italic;
  color: rgba(247, 244, 239, 0.4);
  line-height: 1.72;
  max-width: 620px;
  margin-bottom: 44px;
  animation: fadeUp 1s 0.2s both;
}
.art-meta-row {
  display: flex;
  align-items: center;
  gap: 24px;
  padding-top: 32px;
  border-top: 1px solid rgba(255, 255, 255, 0.07);
  animation: fadeUp 1s 0.3s both;
}
.art-meta-item {
  font-family: 'Josefin Sans', sans-serif;
  font-size: 8px;
  letter-spacing: 0.32em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.22);
}
.art-meta-dot {
  width: 3px;
  height: 3px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
}

/* ═══════════════════════════════════════════
   ARTICLE BODY — PROSE
═══════════════════════════════════════════ */
.art-body {
  max-width: 700px;
  margin: 0 auto;
  padding: 88px 48px;
}
.art-body-content {
  font-size: 19px;
  font-weight: 300;
  line-height: 1.92;
  color: #1A1C18;
}
.art-body-content p {
  margin-bottom: 1.65em;
}
/* Drop cap */
.art-body-content p:first-child::first-letter {
  font-family: 'Cormorant Garamond', serif;
  font-size: 82px;
  font-weight: 600;
  font-style: italic;
  float: left;
  line-height: 0.72;
  margin: 10px 10px 0 0;
  color: var(--green);
}

/* Pull quote */
.art-pull-quote {
  margin: 60px -80px;
  padding: 44px 80px;
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  background: #E4EDD9;
  text-align: center;
}
.apq-text {
  font-size: 27px;
  font-weight: 300;
  font-style: italic;
  line-height: 1.42;
  color: var(--ink);
}
.apq-text em {
  color: var(--green);
  font-style: normal;
}

/* ═══════════════════════════════════════════
   ARTICLE BODY — POEM
═══════════════════════════════════════════ */
.poem-body {
  max-width: 540px;
  margin: 0 auto;
  padding: 88px 48px;
  text-align: center;
}
.poem-epigraph {
  font-family: 'Josefin Sans', sans-serif;
  font-size: 13px;
  font-weight: 300;
  letter-spacing: 0.12em;
  font-style: italic;
  color: var(--mid);
  margin-bottom: 60px;
  padding-bottom: 28px;
  border-bottom: 1px solid var(--border);
}
.poem-stanza {
  margin-bottom: 44px;
}
.poem-line {
  font-size: 21px;
  font-weight: 300;
  font-style: italic;
  line-height: 1.72;
  color: var(--ink);
  display: block;
}
.poem-line.gold { color: var(--gold); }

/* ═══════════════════════════════════════════
   RESPONSIVE
═══════════════════════════════════════════ */
@media (max-width: 900px) {
  nav        { padding: 0 24px; }
  .nav-links { display: none; }

  .hero { grid-template-columns: 1fr; }
