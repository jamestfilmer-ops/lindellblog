<div class="article-page" id="thinkPage">

  <nav class="article-nav">
    <div class="nav-green-bar"></div>
    <button class="back-btn" onclick="showHome(event)">All Writing</button>
    <a class="nav-logo" href="#" style="position:absolute;left:50%;transform:translateX(-50%)" onclick="showHome(event)">
