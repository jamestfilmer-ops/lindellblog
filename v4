<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lindell's Blog</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=Jost:wght@300;400;500&family=Playfair+Display:ital,wght@0,700;1,400&display=swap" rel="stylesheet">
<style>

:root {
  --wood-dark:   #1c1409;
  --wood-mid:    #2e1f0e;
  --wood-warm:   #3d2910;
  --panel:       #241808;
  --leather:     #6b3a1f;
  --brass:       #b8892a;
  --brass-light: #d4a84b;
  --brass-dim:   #8a6620;
  --green:       #1e3a28;
  --green-mid:   #2a5038;
  --green-light: #3a6b4c;
  --green-text:  #c8dbc0;
  --cream:       #f0e8d0;
  --cream-dim:   #c8b890;
  --chalk:       #e8e0c8;
  --amber-glow:  rgba(184,137,42,0.12);
  --rule:        rgba(184,137,42,0.25);
  --rule-bright: rgba(184,137,42,0.5);
  --nav-h:       68px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  background: var(--wood-dark);
  color: var(--cream);
  font-family: 'Jost', sans-serif;
  font-weight: 300;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}

/* ─── NAV ─── */
.nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  height: var(--nav-h);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 3rem;
  border-bottom: 1px solid transparent;
  transition: background 0.4s, border-color 0.4s;
}
.nav.solid {
  background: rgba(28,20,9,0.97);
  backdrop-filter: blur(10px);
  border-color: var(--rule);
}
.nav-logo {
  font-family: 'Perandory', 'Cormorant Garamond', Georgia, serif;
  font-size: 1.5rem;
  font-weight: 400;
  color: var(--brass-light);
  text-decoration: none;
  letter-spacing: 0.05em;
  transition: color 0.2s;
}
.nav-logo:hover { color: var(--cream); }
.nav-links { display: flex; gap: 2.5rem; list-style: none; }
.nav-links a {
  font-size: 0.68rem;
  font-weight: 400;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--cream-dim);
  text-decoration: none;
  transition: color 0.2s;
}
.nav-links a:hover { color: var(--brass-light); }

/* ─── HERO ─── */
.hero {
  position: relative;
  height: 100svh;
  min-height: 600px;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
}

/* Textured wood-grain bg built from CSS */
.hero-bg {
  position: absolute;
  inset: 0;
  background:
    /* photo on top */
    linear-gradient(to bottom,
      rgba(28,20,9,0.25) 0%,
      rgba(28,20,9,0.05) 25%,
      rgba(28,20,9,0.0)  45%,
      rgba(28,20,9,0.65) 75%,
      rgba(28,20,9,0.92) 100%
    ),
    url('/mnt/user-data/uploads/1773805067650_image.png') center 40%/cover no-repeat;
  will-change: transform;
  transform: scale(1.07);
}

/* Green wainscot overlay at bottom */
.hero-wainscot {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 38%;
  background: linear-gradient(to top,
    rgba(30,58,40,0.55) 0%,
    transparent 100%
  );
  pointer-events: none;
}

/* Brass rail line */
.hero-rail {
  position: absolute;
  bottom: 200px;
  left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg,
    transparent 0%,
    var(--rule-bright) 15%,
    var(--brass) 50%,
    var(--rule-bright) 85%,
    transparent 100%
  );
  pointer-events: none;
}

.hero-content {
  position: relative;
  z-index: 2;
  width: 100%;
  padding: 0 3.5rem 3.5rem;
}
.hero-inner {
  max-width: 1200px;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 3rem;
}
.hero-left { flex: 1; }

.hero-eyebrow {
  font-size: 0.62rem;
  font-weight: 400;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--brass-light);
  margin-bottom: 1rem;
  opacity: 0;
  animation: fadeUp 0.7s ease 0.2s forwards;
}
.hero h1 {
  font-family: 'Perandory', 'Cormorant Garamond', Georgia, serif;
  font-size: clamp(4rem, 9vw, 8.5rem);
  font-weight: 400;
  line-height: 0.91;
  letter-spacing: -0.01em;
  color: var(--cream);
  opacity: 0;
  animation: fadeUp 0.95s ease 0.35s forwards;
  text-shadow: 0 2px 30px rgba(28,20,9,0.8);
}
.hero-right {
  flex-shrink: 0;
  max-width: 300px;
  text-align: right;
  opacity: 0;
  animation: fadeUp 0.9s ease 0.55s forwards;
  padding-bottom: 0.6rem;
}
.hero-sub {
  font-family: 'Cormorant Garamond', serif;
  font-style: italic;
  font-size: 1.15rem;
  font-weight: 300;
  line-height: 1.6;
  color: rgba(240,232,208,0.8);
  margin-bottom: 1.5rem;
}
.hero-cta {
  font-size: 0.66rem;
  font-weight: 400;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: var(--brass-light);
  text-decoration: none;
  border-bottom: 1px solid var(--brass-dim);
  padding-bottom: 2px;
  transition: color 0.2s, border-color 0.2s;
}
.hero-cta:hover { color: var(--cream); border-color: var(--cream-dim); }

/* scroll pulse */
.hero-scroll {
  position: absolute;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%);
  z-index: 3;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5px;
  opacity: 0;
  animation: fadeUp 0.8s ease 1.1s forwards;
}
.sd { width: 4px; height: 4px; border-radius: 50%; background: var(--brass-dim); animation: blink 2.2s ease-in-out infinite; }
.sd:nth-child(2) { animation-delay: 0.22s; }
.sd:nth-child(3) { animation-delay: 0.44s; }
@keyframes blink { 0%,100%{opacity:.25;transform:scale(.8)} 50%{opacity:1;transform:scale(1)} }

/* ─── CHALKBOARD STRIP ─── */
.chalk-strip {
  background: var(--green);
  border-top: 3px solid var(--brass-dim);
  border-bottom: 3px solid var(--brass-dim);
  padding: 1.4rem 3.5rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
  position: relative;
  overflow: hidden;
}
.chalk-strip::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(255,255,255,0.012) 2px,
      rgba(255,255,255,0.012) 4px
    );
  pointer-events: none;
}
.chalk-item {
  font-family: 'Cormorant Garamond', serif;
  font-style: italic;
  font-size: 1rem;
  color: var(--chalk);
  opacity: 0.85;
  flex: 1;
  text-align: center;
  position: relative;
}
.chalk-item:not(:last-child)::after {
  content: '·';
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  color: var(--brass-dim);
}

/* ─── MAIN LAYOUT ─── */
.container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 3.5rem;
}

/* wood panel texture for body sections */
.body-section {
  background: var(--wood-mid);
  border-bottom: 1px solid rgba(184,137,42,0.15);
}

.main-grid {
  display: grid;
  grid-template-columns: 1fr 310px;
  gap: 0;
  padding: 5rem 0 6rem;
  align-items: start;
}

/* hairline divider between main and sidebar */
.main-col {
  padding-right: 4rem;
  border-right: 1px solid var(--rule);
}
.sidebar-col {
  padding-left: 3rem;
  position: sticky;
  top: calc(var(--nav-h) + 2rem);
}

/* ─── SECTION LABEL ─── */
.s-label {
  font-size: 0.6rem;
  font-weight: 500;
  letter-spacing: 0.35em;
  text-transform: uppercase;
  color: var(--brass);
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 2.5rem;
}
.s-label::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--rule);
}

/* ─── FEATURED ─── */
.featured {
  padding-bottom: 3.5rem;
  border-bottom: 1px solid var(--rule);
  margin-bottom: 3.5rem;
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.7s ease, transform 0.7s ease;
}
.featured.show { opacity: 1; transform: none; }

.feat-tag {
  font-size: 0.6rem;
  font-weight: 500;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--green-light);
  margin-bottom: 1.2rem;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}
.feat-tag::before {
  content: '';
  display: inline-block;
  width: 18px;
  height: 1px;
  background: var(--green-light);
}
.featured h2 {
  font-family: 'Perandory', 'Cormorant Garamond', Georgia, serif;
  font-size: clamp(2.6rem, 4vw, 4.2rem);
  font-weight: 400;
  line-height: 1.0;
  letter-spacing: -0.01em;
  color: var(--cream);
  margin-bottom: 1rem;
}
.featured h2 a { color: inherit; text-decoration: none; transition: color 0.2s; }
.featured h2 a:hover { color: var(--brass-light); }

.feat-meta {
  font-size: 0.65rem;
  font-weight: 400;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--brass-dim);
  margin-bottom: 1.8rem;
  display: flex; align-items: center; gap: 0.6rem;
}
.feat-meta-dot { color: var(--rule-bright); }

.feat-excerpt {
  font-family: 'Cormorant Garamond', serif;
  font-style: italic;
  font-size: 1.18rem;
  font-weight: 300;
  line-height: 1.9;
  color: rgba(240,232,208,0.75);
  margin-bottom: 2rem;
  max-width: 640px;
}
.feat-excerpt::first-letter {
  font-family: 'Playfair Display', serif;
  font-size: 4rem;
  font-weight: 700;
  font-style: normal;
  float: left;
  line-height: 0.82;
  margin: 0.06em 0.1em 0 0;
  color: var(--brass-light);
}

.btn-read {
  display: inline-flex;
  align-items: center;
  gap: 0.7rem;
  font-size: 0.66rem;
  font-weight: 500;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--cream);
  text-decoration: none;
  background: var(--green);
  border: 1px solid var(--green-light);
  padding: 0.8rem 1.6rem;
  transition: background 0.2s, border-color 0.2s, color 0.2s;
}
.btn-read:hover {
  background: var(--green-mid);
  border-color: var(--brass-dim);
  color: var(--brass-light);
}
.btn-read-arrow { transition: transform 0.2s; }
.btn-read:hover .btn-read-arrow { transform: translateX(4px); }

/* ─── POST ROWS ─── */
.rows-label {
  font-size: 0.6rem;
  font-weight: 400;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--brass-dim);
  padding-bottom: 0.8rem;
  border-bottom: 1px solid var(--rule);
  margin-bottom: 0;
}
.post-list { list-style: none; }

.post-row {
  display: grid;
  grid-template-columns: 56px 1fr 20px;
  gap: 0 1.8rem;
  align-items: start;
  padding: 1.8rem 0;
  border-bottom: 1px solid rgba(184,137,42,0.12);
  cursor: pointer;
  opacity: 0;
  transform: translateY(14px);
  transition: opacity 0.5s ease, transform 0.5s ease, background 0.2s;
  border-radius: 2px;
}
.post-row.show { opacity: 1; transform: none; }
.post-row:hover { background: rgba(184,137,42,0.04); }
.post-row:hover .prow-title { color: var(--brass-light); }

.prow-date {
  text-align: right;
  padding-top: 0.2rem;
  border-right: 1px solid var(--rule);
  padding-right: 1.4rem;
}
.prow-day {
  display: block;
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.7rem;
  font-weight: 300;
  color: var(--brass);
  line-height: 1;
}
.prow-mon {
  display: block;
  font-size: 0.55rem;
  font-weight: 400;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--brass-dim);
  margin-top: 2px;
}
.prow-body { padding-left: 0.2rem; }
.prow-cat {
  font-size: 0.58rem;
  font-weight: 400;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--green-light);
  margin-bottom: 0.3rem;
}
.prow-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.3rem;
  font-weight: 400;
  line-height: 1.28;
  color: var(--cream);
  margin-bottom: 0.45rem;
  transition: color 0.2s;
}
.prow-snip {
  font-size: 0.86rem;
  font-weight: 300;
  line-height: 1.65;
  color: rgba(200,184,144,0.65);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.prow-arrow {
  font-size: 0.85rem;
  color: var(--brass-dim);
  align-self: center;
  transition: transform 0.2s, color 0.2s;
}
.post-row:hover .prow-arrow { transform: translateX(3px); color: var(--brass-light); }

/* ─── SIDEBAR ─── */
.sb-block {
  margin-bottom: 2.8rem;
  opacity: 0;
  transform: translateY(16px);
  transition: opacity 0.6s ease, transform 0.6s ease;
}
.sb-block.show { opacity: 1; transform: none; }

.sb-head {
  font-size: 0.58rem;
  font-weight: 500;
  letter-spacing: 0.35em;
  text-transform: uppercase;
  color: var(--brass);
  padding-bottom: 0.75rem;
  border-bottom: 1px solid var(--rule);
  margin-bottom: 1.4rem;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}
.sb-head::before {
  content: '';
  display: inline-block;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--brass);
  flex-shrink: 0;
}

/* author card */
.author-card {
  background: var(--panel);
  border: 1px solid var(--rule);
  padding: 1.4rem;
  position: relative;
  overflow: hidden;
}
.author-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, var(--brass-dim), var(--brass-light), var(--brass-dim));
}
.author-avatar {
  width: 54px;
  height: 54px;
  border-radius: 50%;
  object-fit: cover;
  border: 2px solid var(--brass-dim);
  display: block;
  margin-bottom: 1rem;
}
.author-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.15rem;
  font-weight: 400;
  color: var(--cream);
  margin-bottom: 0.35rem;
}
.author-bio {
  font-size: 0.84rem;
  font-weight: 300;
  line-height: 1.65;
  color: rgba(200,184,144,0.7);
}

/* archive */
.arch-list { list-style: none; }
.arch-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0.55rem 0;
  border-bottom: 1px solid rgba(184,137,42,0.1);
}
.arch-row:last-child { border-bottom: none; }
.arch-row a {
  font-size: 0.86rem;
  font-weight: 300;
  color: var(--cream-dim);
  text-decoration: none;
  transition: color 0.2s;
}
.arch-row a:hover { color: var(--brass-light); }
.arch-pill {
  font-size: 0.6rem;
  font-weight: 400;
  color: var(--brass-dim);
  background: rgba(184,137,42,0.1);
  border: 1px solid rgba(184,137,42,0.2);
  padding: 0.12rem 0.5rem;
  border-radius: 20px;
}

/* tags */
.tag-cloud { display: flex; flex-wrap: wrap; gap: 0.4rem; }
.tag {
  font-size: 0.58rem;
  font-weight: 400;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--cream-dim);
  text-decoration: none;
  border: 1px solid rgba(184,137,42,0.2);
  padding: 0.28rem 0.65rem;
  transition: all 0.18s;
}
.tag:hover {
  background: var(--green);
  color: var(--green-text);
  border-color: var(--green-mid);
}

/* ─── DIVIDER ─── */
.brass-divider {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 2.5rem 0 0;
}
.brass-divider::before,
.brass-divider::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--rule);
}
.brass-divider-gem {
  width: 8px;
  height: 8px;
  background: var(--brass);
  transform: rotate(45deg);
  flex-shrink: 0;
}

/* ─── QUOTE BAND ─── */
.quote-band {
  background: var(--green);
  border-top: 2px solid var(--brass-dim);
  border-bottom: 2px solid var(--brass-dim);
  padding: 5rem 3.5rem;
  text-align: center;
  position: relative;
  overflow: hidden;
}
/* chalkboard lines */
.quote-band::before {
  content: '';
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    0deg,
    transparent,
    transparent 3px,
    rgba(255,255,255,0.018) 3px,
    rgba(255,255,255,0.018) 4px
  );
  pointer-events: none;
}
.quote-inner {
  position: relative;
  z-index: 1;
  max-width: 780px;
  margin: 0 auto;
  opacity: 0;
  transform: translateY(18px);
  transition: opacity 0.7s, transform 0.7s;
}
.quote-inner.show { opacity: 1; transform: none; }
.quote-mark {
  font-family: 'Playfair Display', serif;
  font-size: 5rem;
  font-weight: 700;
  color: var(--brass-dim);
  line-height: 0.6;
  margin-bottom: 1rem;
  display: block;
  opacity: 0.6;
}
.quote-band blockquote {
  font-family: 'Cormorant Garamond', serif;
  font-style: italic;
  font-size: clamp(1.4rem, 2.8vw, 2.2rem);
  font-weight: 300;
  line-height: 1.6;
  color: var(--chalk);
  margin-bottom: 1.5rem;
}
.quote-band cite {
  font-size: 0.62rem;
  font-weight: 400;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--brass-dim);
}

/* ─── FOOTER ─── */
footer {
  background: var(--panel);
  border-top: 1px solid var(--rule);
  padding: 3.5rem 3.5rem 2.5rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
}
.foot-logo {
  font-family: 'Perandory', 'Cormorant Garamond', Georgia, serif;
  font-size: 2.4rem;
  font-weight: 400;
  color: var(--brass-light);
  letter-spacing: 0.05em;
}
.foot-sub {
  font-family: 'Cormorant Garamond', serif;
  font-style: italic;
  font-size: 0.95rem;
  color: var(--brass-dim);
}
.foot-rule {
  width: 50px;
  height: 1px;
  background: var(--rule);
  margin: 0.5rem 0;
}
.foot-copy {
  font-size: 0.6rem;
  font-weight: 400;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: rgba(184,137,42,0.3);
}

/* ─── ANIMATIONS ─── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(18px); }
  to   { opacity: 1; transform: none; }
}

/* ─── RESPONSIVE ─── */
@media (max-width: 900px) {
  .main-grid { grid-template-columns: 1fr; gap: 3rem; }
  .main-col { padding-right: 0; border-right: none; }
  .sidebar-col { position: static; padding-left: 0; padding-top: 3rem; border-top: 1px solid var(--rule); }
  .nav { padding: 0 1.5rem; }
  .container { padding: 0 1.5rem; }
  .hero-content { padding: 0 1.5rem 2.5rem; }
  .hero-inner { flex-direction: column; align-items: flex-start; gap: 1.5rem; }
  .hero-right { text-align: left; max-width: 100%; }
  .chalk-strip { padding: 1.2rem 1.5rem; flex-wrap: wrap; }
  .quote-band { padding: 3.5rem 1.5rem; }
  footer { padding: 2.5rem 1.5rem 2rem; }
}
</style>
</head>
<body>

<!-- NAV -->
<nav class="nav" id="nav">
  <a href="#" class="nav-logo">Lindell</a>
  <ul class="nav-links">
    <li><a href="#">Home</a></li>
    <li><a href="#">Stories</a></li>
    <li><a href="#">Essays</a></li>
    <li><a href="#">Archive</a></li>
  </ul>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-bg" id="hero-bg"></div>
  <div class="hero-wainscot"></div>
  <div class="hero-rail"></div>

  <div class="hero-content">
