<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lindell's Blog</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,700;1,300;1,400;1,700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>

/* ─────────────────────────────────────────
   TOKENS
───────────────────────────────────────── */
:root {
  --paper:     #f7f4ef;
  --white:     #ffffff;
  --ink:       #111009;

  --blue:      #2d6478;
  --blue-mid:  #3d7e94;
  --blue-pale: #d0e6ed;
  --blue-wash: #eaf3f6;

  --mah:       #5c2412;
  --mah-mid:   #8b3d20;
  --mah-light: #b06040;
  --mah-pale:  #f2e0d4;

  --gold:      #b89050;
  --rule:      rgba(17,16,9,0.1);
}

/* ─────────────────────────────────────────
   RESET + BASE
───────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; font-size: 16px; }

body {
  background: var(--paper);
  color: var(--ink);
  font-family: 'DM Sans', sans-serif;
  font-weight: 300;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
  cursor: none;
}

/* ─────────────────────────────────────────
   CUSTOM CURSOR
───────────────────────────────────────── */
.cursor {
  position: fixed;
  width: 10px; height: 10px;
  border-radius: 50%;
  background: var(--blue);
  pointer-events: none;
  z-index: 9999;
  transform: translate(-50%, -50%);
  transition: transform 0.08s, width 0.25s, height 0.25s, background 0.25s;
  mix-blend-mode: multiply;
}
.cursor.big {
  width: 40px; height: 40px;
  background: var(--mah-mid);
}

/* ─────────────────────────────────────────
   NAV — floats over everything
───────────────────────────────────────── */
.nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 500;
  padding: 1.8rem 3rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  mix-blend-mode: normal;
  transition: padding 0.3s;
}
.nav.scrolled { padding: 1.2rem 3rem; }

.nav-logo {
  font-family: 'Perandory', 'Cormorant Garamond', Georgia, serif;
  font-size: 1.4rem;
  font-weight: 400;
  letter-spacing: 0.06em;
  text-decoration: none;
  color: var(--white);
  mix-blend-mode: difference;
  filter: invert(0);
  transition: opacity 0.2s;
}
.nav-links {
  display: flex;
  gap: 2.5rem;
  list-style: none;
}
.nav-links a {
  font-size: 0.65rem;
  font-weight: 400;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  text-decoration: none;
  color: var(--white);
  mix-blend-mode: difference;
  transition: opacity 0.2s;
}
.nav-links a:hover { opacity: 0.6; }

/* ─────────────────────────────────────────
   HERO — SPLIT SCREEN
   Left: photo bleeding edge-to-center
   Right: large title on paper
───────────────────────────────────────── */
.hero {
  display: grid;
  grid-template-columns: 55% 45%;
  height: 100svh;
  min-height: 600px;
  position: relative;
}

/* LEFT PANEL — photo */
.hero-photo-panel {
  position: relative;
  overflow: hidden;
}
.hero-photo-img {
  position: absolute;
  inset: -8%;
  background: url('/mnt/user-data/uploads/1773805067650_image.png') center 40%/cover no-repeat;
  will-change: transform;
  transition: none;
}
/* Soft diagonal mask into the right panel */
.hero-photo-panel::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(105deg,
    transparent 0%,
    transparent 60%,
    var(--paper) 100%
  );
  pointer-events: none;
}

/* RIGHT PANEL — title on paper */
.hero-text-panel {
  background: var(--paper);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 0 4rem 4.5rem 3rem;
  position: relative;
}

/* Huge italic number watermark */
.hero-issue {
  position: absolute;
  top: 6rem;
  right: 3.5rem;
  font-family: 'Cormorant Garamond', serif;
  font-size: 16rem;
  font-weight: 700;
  line-height: 1;
  color: rgba(45,100,120,0.06);
  user-select: none;
  pointer-events: none;
}

.hero-eyebrow {
  font-size: 0.6rem;
  font-weight: 400;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--blue-mid);
  margin-bottom: 1.2rem;
  opacity: 0;
  animation: riseIn 0.7s ease 0.3s forwards;
}

.hero-title {
  font-family: 'Perandory', 'Cormorant Garamond', Georgia, serif;
  font-size: clamp(3.5rem, 6vw, 6.5rem);
  font-weight: 400;
  line-height: 0.92;
  letter-spacing: -0.02em;
  color: var(--ink);
  margin-bottom: 1.8rem;
  opacity: 0;
  animation: riseIn 0.95s ease 0.45s forwards;
}

/* Horizontal rule with inset text */
.hero-rule {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 1.6rem;
  opacity: 0;
  animation: riseIn 0.8s ease 0.65s forwards;
}
.hero-rule-line { flex: 1; height: 1px; background: var(--mah); }
.hero-rule-text {
  font-family: 'Cormorant Garamond', serif;
  font-style: italic;
  font-size: 0.95rem;
  color: var(--mah-mid);
  white-space: nowrap;
}

.hero-desc {
  font-size: 0.88rem;
  font-weight: 300;
  line-height: 1.75;
  color: #555;
  max-width: 320px;
  margin-bottom: 2.2rem;
  opacity: 0;
  animation: riseIn 0.8s ease 0.8s forwards;
}

.hero-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.8rem;
  font-size: 0.65rem;
  font-weight: 500;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  text-decoration: none;
  color: var(--white);
  background: var(--mah);
  padding: 1rem 2rem;
  width: fit-content;
  position: relative;
  overflow: hidden;
  opacity: 0;
  animation: riseIn 0.8s ease 1s forwards;
  transition: background 0.25s;
}
.hero-btn::before {
  content: '';
  position: absolute;
  inset: 0;
  background: var(--blue);
  transform: translateX(-101%);
  transition: transform 0.3s ease;
}
.hero-btn:hover::before { transform: translateX(0); }
.hero-btn span { position: relative; z-index: 1; }
.hero-btn-arrow { position: relative; z-index: 1; transition: transform 0.2s; }
.hero-btn:hover .hero-btn-arrow { transform: translateX(5px); }

/* Caption on photo */
.hero-caption {
  position: absolute;
  bottom: 2rem;
  left: 2rem;
  font-size: 0.58rem;
  font-weight: 400;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.55);
  z-index: 2;
  writing-mode: vertical-rl;
  transform: rotate(180deg);
}

/* ─────────────────────────────────────────
   TICKER BAND
───────────────────────────────────────── */
.ticker-wrap {
  background: var(--blue);
  overflow: hidden;
  padding: 0.75rem 0;
  border-top: 1px solid rgba(255,255,255,0.1);
}
.ticker-track {
  display: flex;
  width: max-content;
  animation: ticker 28s linear infinite;
}
.ticker-item {
  font-size: 0.6rem;
  font-weight: 400;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: rgba(200,225,235,0.75);
  padding: 0 2.5rem;
  white-space: nowrap;
  flex-shrink: 0;
}
.ticker-sep {
  color: rgba(90,160,180,0.5);
  padding: 0 0.5rem;
}
@keyframes ticker {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}

/* ─────────────────────────────────────────
   MAIN CONTENT
   Asymmetric: big featured left, 
   posts in a stacked right column
───────────────────────────────────────── */
.content-wrap {
  display: grid;
  grid-template-columns: 1fr 420px;
  min-height: 100vh;
}

/* ── LEFT: featured post ── */
.featured-panel {
  background:
    radial-gradient(ellipse 70% 50% at 110% 20%, rgba(45,100,120,0.07) 0%, transparent 60%),
    radial-gradient(ellipse 60% 40% at -10% 90%, rgba(92,36,18,0.06) 0%, transparent 55%),
    var(--white);
  padding: 6rem 5rem 6rem 3.5rem;
  border-right: 1px solid var(--rule);
  position: relative;
  overflow: hidden;
}

/* top-left corner bracket accent */
.featured-panel::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 80px; height: 80px;
  border-top: 3px solid var(--blue-pale);
  border-left: 3px solid var(--blue-pale);
  pointer-events: none;
}
/* bottom-right corner bracket — mahogany */
.featured-panel::after {
  content: '';
  position: absolute;
  bottom: 0; right: 0;
  width: 80px; height: 80px;
  border-bottom: 3px solid var(--mah-pale);
  border-right: 3px solid var(--mah-pale);
  pointer-events: none;
}

/* Large rotated "FEATURED" text */
.feat-watermark {
  position: absolute;
  top: 50%;
  left: -4rem;
  transform: translateY(-50%) rotate(-90deg);
  font-family: 'Cormorant Garamond', serif;
  font-size: 7rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(45,100,120,0.05);
  user-select: none;
  pointer-events: none;
  white-space: nowrap;
}

.feat-number {
  font-family: 'Cormorant Garamond', serif;
  font-size: 0.7rem;
  font-weight: 400;
  letter-spacing: 0.3em;
  color: var(--mah-light);
  margin-bottom: 0.5rem;
}
.feat-tag {
  display: inline-block;
  font-size: 0.58rem;
  font-weight: 500;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--white);
  background: var(--blue);
  padding: 0.3rem 0.7rem;
  margin-bottom: 2rem;
}
.feat-title {
  font-family: 'Perandory', 'Cormorant Garamond', Georgia, serif;
  font-size: clamp(3rem, 4.5vw, 5rem);
  font-weight: 400;
  line-height: 0.95;
  letter-spacing: -0.02em;
  color: var(--ink);
  margin-bottom: 1.5rem;
}
.feat-title a { color: inherit; text-decoration: none; }
.feat-title a:hover { color: var(--mah); }

.feat-meta {
  font-size: 0.62rem;
  font-weight: 400;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--blue-mid);
  margin-bottom: 2rem;
  display: flex; align-items: center; gap: 0.6rem;
}
.feat-meta-dot { color: var(--blue-pale); }

/* Excerpt with Mahogany drop cap */
.feat-excerpt {
  font-family: 'Cormorant Garamond', serif;
  font-style: italic;
  font-size: 1.2rem;
  font-weight: 300;
  line-height: 1.88;
  color: #333;
  margin-bottom: 3rem;
  max-width: 580px;
  background: var(--blue-wash);
  border-left: 3px solid var(--blue-mid);
  padding: 1.4rem 1.6rem 1.4rem 1.8rem;
}
.feat-excerpt::first-letter {
  font-size: 5rem;
  font-weight: 700;
  font-style: normal;
  float: left;
  line-height: 0.78;
  margin: 0.06em 0.1em 0 0;
  color: var(--mah);
}

.feat-read {
  display: inline-flex;
  align-items: center;
  gap: 1rem;
  font-size: 0.63rem;
  font-weight: 500;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: var(--ink);
  text-decoration: none;
}
.feat-read-line {
  width: 40px;
  height: 1px;
  background: var(--mah);
  transition: width 0.3s;
}
.feat-read:hover .feat-read-line { width: 80px; }
.feat-read:hover { color: var(--mah); }

/* ── RIGHT: stacked posts ── */
.posts-panel {
  background:
    linear-gradient(160deg, rgba(45,100,120,0.06) 0%, transparent 40%),
    var(--paper);
  display: flex;
  flex-direction: column;
  position: relative;
}
/* decorative vertical blue stripe on the left edge */
.posts-panel::before {
  content: '';
  position: absolute;
  top: 0; left: 0; bottom: 0;
  width: 3px;
  background: linear-gradient(to bottom, var(--blue-pale), var(--mah-pale), var(--blue-pale));
  pointer-events: none;
}

/* Panel header */
.posts-header {
  background: var(--mah);
  padding: 2rem 2.5rem;
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 1rem;
}
.posts-header-label {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.5rem;
  font-weight: 400;
  font-style: italic;
  color: var(--mah-pale);
  letter-spacing: 0.02em;
}
.posts-header-count {
  font-size: 0.58rem;
  font-weight: 400;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: rgba(242,224,212,0.5);
}

/* Individual post cards */
.post-card {
  padding: 2rem 2.5rem;
  border-bottom: 1px solid var(--rule);
  cursor: pointer;
  display: grid;
  grid-template-columns: 44px 1fr;
  gap: 1.5rem;
  align-items: start;
  opacity: 0;
  transform: translateX(20px);
  transition: opacity 0.5s, transform 0.5s, background 0.2s;
  position: relative;
}
.post-card::after {
  content: '→';
  position: absolute;
  right: 1.5rem;
  top: 50%;
  transform: translateY(-50%) translateX(4px);
  font-size: 0.85rem;
  color: var(--blue-pale);
  transition: color 0.2s, transform 0.2s;
  opacity: 0;
}
.post-card:hover::after {
  opacity: 1;
  color: var(--blue-mid);
  transform: translateY(-50%) translateX(0);
}
/* alternate tints */
.post-card:nth-child(odd)  { background: rgba(45,100,120,0.03); }
.post-card:nth-child(even) { background: rgba(92,36,18,0.025); }
.post-card.show { opacity: 1; transform: none; }
.post-card:hover { background: rgba(45,100,120,0.08) !important; }
.post-card:hover .pc-title { color: var(--blue); }
.post-card:last-child { border-bottom: none; }

.pc-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 2rem;
  font-weight: 300;
  color: var(--blue-mid);
  line-height: 1;
  text-align: right;
  opacity: 0.5;
}
.pc-cat {
  font-size: 0.55rem;
  font-weight: 500;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--mah-light);
  margin-bottom: 0.3rem;
  display: flex;
  align-items: center;
  gap: 0.4rem;
}
.pc-cat::before {
  content: '';
  display: inline-block;
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--mah-light);
  flex-shrink: 0;
}
.pc-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.2rem;
  font-weight: 400;
  line-height: 1.3;
  color: var(--ink);
  margin-bottom: 0.4rem;
  transition: color 0.2s;
}
.pc-meta {
  font-size: 0.6rem;
  font-weight: 300;
  color: #999;
  margin-bottom: 0.45rem;
}
.pc-snip {
  font-size: 0.82rem;
  font-weight: 300;
  line-height: 1.6;
  color: #777;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ─────────────────────────────────────────
   SIDEBAR STRIP — below content grid
   Full-width: three columns
───────────────────────────────────────── */
.info-strip {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  border-top: 1px solid var(--rule);
}
.info-block {
  padding: 3.5rem;
  border-right: 1px solid var(--rule);
  opacity: 0;
  transform: translateY(16px);
  transition: opacity 0.6s, transform 0.6s;
  position: relative;
}
/* Blue tint on first, mahogany on second, neutral on third */
.info-block:nth-child(1) { background: var(--blue-wash); }
.info-block:nth-child(2) { background: var(--mah-pale); }
.info-block:nth-child(3) { background: var(--paper); }
/* top color pip per block */
.info-block:nth-child(1)::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: var(--blue); }
.info-block:nth-child(2)::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: var(--mah); }
.info-block:nth-child(3)::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: var(--gold); }
.info-block:last-child { border-right: none; }
.info-block.show { opacity: 1; transform: none; }

.info-label {
  font-size: 0.56rem;
  font-weight: 500;
  letter-spacing: 0.32em;
  text-transform: uppercase;
  color: var(--blue-mid);
  padding-bottom: 0.8rem;
  border-bottom: 1px solid var(--blue-pale);
  margin-bottom: 1.5rem;
}
.info-block:nth-child(2) .info-label {
  color: var(--mah-mid);
  border-bottom-color: rgba(92,36,18,0.2);
}
.info-block:nth-child(3) .info-label {
  color: var(--gold);
  border-bottom-color: rgba(184,144,80,0.25);
}

/* Author block */
.author-row {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 0.9rem;
}
.author-img {
  width: 48px; height: 48px;
  border-radius: 50%;
  object-fit: cover;
  border: 2px solid var(--mah-pale);
  flex-shrink: 0;
}
.author-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.1rem;
  font-weight: 400;
  color: var(--ink);
}
.author-bio {
  font-size: 0.83rem;
  font-weight: 300;
  line-height: 1.65;
  color: #666;
}

/* Archive block */
.arch-list { list-style: none; }
.arch-row {
  display: flex;
  justify-content: space-between;
  padding: 0.55rem 0;
  border-bottom: 1px solid rgba(17,16,9,0.06);
  align-items: center;
}
.arch-row:last-child { border: none; }
.arch-row a {
  font-size: 0.86rem;
  font-weight: 300;
  color: var(--ink);
  text-decoration: none;
  transition: color 0.2s;
}
.arch-row a:hover { color: var(--blue); }
.arch-n {
  font-size: 0.6rem;
  color: var(--blue-mid);
  background: var(--blue-wash);
  padding: 0.1rem 0.45rem;
  border-radius: 20px;
}

/* Tags block */
.tag-cloud { display: flex; flex-wrap: wrap; gap: 0.4rem; }
.tag {
  font-size: 0.56rem;
  font-weight: 400;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #666;
  text-decoration: none;
  border: 1px solid var(--rule);
  padding: 0.28rem 0.6rem;
  transition: all 0.18s;
}
.tag:hover {
  color: var(--white);
  background: var(--mah);
  border-color: var(--mah);
}

/* ─────────────────────────────────────────
   QUOTE — full-bleed photo + text overlay
───────────────────────────────────────── */
.quote-section {
  position: relative;
  height: 60vh;
  min-height: 400px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.quote-photo {
  position: absolute;
  inset: -6%;
  background: url('/mnt/user-data/uploads/1773805067650_image.png') center 60%/cover no-repeat;
  filter: brightness(0.35) saturate(0.7);
  will-change: transform;
}
.quote-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg,
    rgba(92,36,18,0.6) 0%,
    rgba(45,100,120,0.5) 100%
  );
}
.quote-content {
  position: relative;
  z-index: 2;
  text-align: center;
  padding: 3rem;
  max-width: 820px;
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.8s, transform 0.8s;
}
.quote-content.show { opacity: 1; transform: none; }
.quote-text {
  font-family: 'Cormorant Garamond', serif;
  font-style: italic;
  font-size: clamp(1.5rem, 3vw, 2.4rem);
  font-weight: 300;
  line-height: 1.55;
  color: rgba(247,244,239,0.95);
  margin-bottom: 1.5rem;
}
.quote-attr {
  font-size: 0.6rem;
  font-weight: 400;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: rgba(200,225,235,0.6);
}

/* ─────────────────────────────────────────
   FOOTER
───────────────────────────────────────── */
footer {
  background: var(--ink);
  padding: 3rem;
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  gap: 2rem;
}
.foot-left {
  font-size: 0.58rem;
  font-weight: 300;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.2);
}
.foot-center {
  font-family: 'Perandory', 'Cormorant Garamond', Georgia, serif;
  font-size: 2rem;
  font-weight: 400;
  color: rgba(255,255,255,0.85);
  letter-spacing: 0.06em;
  text-align: center;
}
.foot-right {
  font-size: 0.58rem;
  font-weight: 300;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.2);
  text-align: right;
}

/* ─────────────────────────────────────────
   ANIMATIONS
───────────────────────────────────────── */
@keyframes riseIn {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: none; }
}

/* ─────────────────────────────────────────
   RESPONSIVE
───────────────────────────────────────── */
@media (max-width: 1000px) {
