<script>
/* cursor */
const cursor = document.getElementById('cursor');
document.addEventListener('mousemove', e => {
  cursor.style.left = e.clientX + 'px';
  cursor.style.top  = e.clientY + 'px';
});
document.querySelectorAll('a, button, .post-card').forEach(el => {
  el.addEventListener('mouseenter', () => cursor.classList.add('big'));
  el.addEventListener('mouseleave', () => cursor.classList.remove('big'));
});

/* nav */
const nav = document.getElementById('nav');
window.addEventListener('scroll', () => {
  nav.classList.toggle('scrolled', window.scrollY > 40);
}, { passive: true });

/* parallax */
const heroImg   = document.getElementById('hero-img');
const quotePhoto = document.getElementById('quote-photo');
window.addEventListener('scroll', () => {
  const y = window.scrollY;
  if (heroImg)    heroImg.style.transform    = `scale(1.08) translateY(${y * 0.18}px)`;
  if (quotePhoto) {
    const rect = quotePhoto.parentElement.getBoundingClientRect();
    const offset = (rect.top + rect.height / 2 - window.innerHeight / 2) * 0.18;
    quotePhoto.style.transform = `scale(1.06) translateY(${offset}px)`;
  }
}, { passive: true });

/* scroll reveals */
const io = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (!e.isIntersecting) return;
    const el = e.target;
    if (el.classList.contains('post-card')) {
      const cards = [...document.querySelectorAll('.post-card')];
      setTimeout(() => el.classList.add('show'), cards.indexOf(el) * 110);
    } else {
      el.classList.add('show');
    }
    io.unobserve(el);
  });
}, { threshold: 0.1 });

['pc1','pc2','pc3','pc4','ib1','ib2','ib3','quote-content']
  .forEach(id => { const el = document.getElementById(id); if(el) io.observe(el); });
</script>
