<script>
const swatches = [
  { hex:'#F2EDE4', label:'Primary 1',  pct:30 },
  { hex:'#EDE4D8', label:'Primary 2',  pct:30 },
  { hex:'#B41818', label:'Accent 1',   pct:8  },
  { hex:'#C07818', label:'Accent 2',   pct:8  },
  { hex:'#D4A860', label:'Tertiary 1', pct:4  },
  { hex:'#C06050', label:'Tertiary 2', pct:4  },
  { hex:'#1C1208', label:'Text',       pct:3  },
  { hex:'#885030', label:'Borders',    pct:3  },
];

function lum(h){
  const r=parseInt(h.slice(1,3),16)/255,g=parseInt(h.slice(3,5),16)/255,b=parseInt(h.slice(5,7),16)/255;
  const f=c=>c<=.03928?c/12.92:Math.pow((c+.055)/1.055,2.4);
  return .2126*f(r)+.7152*f(g)+.0722*f(b);
}
function tc(h){ return lum(h)>.35?'#1a1208':'#f5ede4'; }

const row = document.getElementById('palrow');
swatches.forEach(s=>{
  const d = document.createElement('div');
  d.className = 'swatch';
  d.style.cssText = `background:${s.hex};--flex:${s.pct}`;
  d.innerHTML = `<span class="sw-pct" style="color:${tc(s.hex)}">${s.pct}%</span><span class="sw-name" style="color:${tc(s.hex)}">${s.label}</span>`;
  d.title = `${s.label}: ${s.hex}`;
  d.addEventListener('click',()=>{ navigator.clipboard?.writeText(s.hex); d.style.outline='2px solid '+tc(s.hex); setTimeout(()=>d.style.outline='',700); });
  row.appendChild(d);
});

const grid = document.getElementById('swgrid');
swatches.forEach(s=>{
  const d = document.createElement('div');
  d.className = 'sw-card';
  d.innerHTML = `<div class="sw-color" style="background:${s.hex}"></div><div class="sw-info"><div class="sw-hex">${s.hex}</div><div class="sw-label">${s.label} · ${s.pct}%</div></div>`;
  grid.appendChild(d);
});
</script>
