<script>
const nav = document.getElementById('nav');
const photo = document.getElementById('hero-photo');

window.addEventListener('scroll', () => {
  const y = window.scrollY;
  nav.classList.toggle('solid', y > 50);
  if (photo) photo.style.transform = `scale(1.06) translateY(${y * 0.22}px)`;
}, { passive: true });

const io = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (!e.isIntersecting) return;
    const el = e.target;
    if (el.classList.contains('post-row')) {
      const rows = [...document.querySelectorAll('.post-row')];
      setTimeout(() => el.classList.add('show'), rows.indexOf(el) * 100);
    } else {
      el.classList.add('show');
    }
    io.unobserve(el);
  });
}, { threshold: 0.1 });

document.querySelectorAll('.reveal, .post-row').forEach(el => io.observe(el));
</script>
